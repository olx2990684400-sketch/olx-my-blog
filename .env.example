# ── Cloudflare 凭证（必填） ──────────────────────────

# API Token：用于构建脚本上传向量到 Vectorize
# 获取方式：
#   1. 登录 https://dash.cloudflare.com
#   2. 右上角头像 > My Profile > API Tokens > Create Token
#   3. 选择「Custom token」，权限勾选：
#      - Account > Vectorize > Edit
#      - Account > Workers AI > Use
#   4. 创建后复制 Token（只显示一次）
CLOUDFLARE_API_TOKEN=your_token_here

# Account ID：Cloudflare 账户唯一标识
# 获取方式：
#   1. 登录 https://dash.cloudflare.com
#   2. 任意域名概览 > 右侧栏「API」区域 > Account ID
#   3. 或直接从 URL 中复制：https://dash.cloudflare.com/<account_id>/...
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# ── 第三方 AI API（可选） ───────────────────────────

# AI API Key：用于调用第三方 Embedding / Chat API
# 配置后走第三方 API（效果更好），不配则回退 Cloudflare Workers AI 免费模型
# 当前使用魔搭社区（ModelScope）的免费接口，注册即可获取
# 注册地址：https://modelscope.cn
# 获取方式：登录 > 右上角头像 > API-KEY 管理 > 创建 API Key
AI_API_KEY=your_api_key_here

# 允许调用 Worker AI 接口的站点来源，多个来源用英文逗号分隔
ALLOWED_ORIGINS=https://your-domain.example

# ── GitHub App 认证（在线编辑功能需要） ───────────────

# GitHub App ID：你的 GitHub App 的唯一标识
# 获取方式：https://github.com/settings/apps > 选择你的 App > 查看 App ID
GH_APP_ID=your_app_id_here
PUBLIC_GITHUB_APP_ID=your_app_id_here

# GitHub Private Key：GitHub App 的私钥（PEM 格式）
# 获取方式：https://github.com/settings/apps > 选择你的 App > Private keys > Generate a private key
# 注意：将整个 PEM 文件内容粘贴到这里，包括 BEGIN 和 END 标记
# 换行符用 \n 表示（不要使用实际的换行）
# 示例：GH_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"
GH_PRIVATE_KEY="your_pem_private_key_here"

# GitHub 用户名（仓库所有者）
GH_USER=olx2990684400-sketch
PUBLIC_GITHUB_OWNER=olx2990684400-sketch

# GitHub 仓库名称
GH_REPO=olx-my-blog
PUBLIC_GITHUB_REPO=olx-my-blog

# GitHub 仓库分支
PUBLIC_GITHUB_BRANCH=master
