---
import { getCollection } from "astro:content";
import Comment from "@components/comment/index.astro";
import { Icon } from "astro-icon/components";
import ClientPagination from "@/components/common/ClientPagination.astro";
import MovieGameCard from "@/components/pages/movies-games/MovieGameCard.astro";
import BangumiEditor from "@/components/edit/BangumiEditor.svelte";
import { siteConfig } from "@/config";
import { externalBangumiConfig } from "@/config/externalBangumiConfig";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { formatDateI18nWithTime } from "@/utils/date-utils";
import { removeFileExtension } from "@/utils/url-utils";

if (!siteConfig.pages.moviesGames) {
	return Astro.redirect("/404/");
}

const buildTime = formatDateI18nWithTime(new Date());

const customBangumi = await getCollection("bangumi");

const statusMap: Record<number, string> = {
	1: "wish",
	2: "collect",
	3: "doing",
	4: "on_hold",
	5: "dropped",
};

interface MgItem {
	subject_id: number;
	subject_type: number;
	rate: number;
	type: number;
	comment: string | null;
	tags: string[];
	ep_status: number;
	vol_status: number;
	updated_at: string;
	private: boolean;
	link: string;
	subject: {
		id: number;
		type: number;
		name: string;
		name_cn: string;
		short_summary: string;
		images: {
			medium: string;
			large: string;
			common: string;
			small: string;
			grid: string;
		};
		volumes: number;
		eps: number;
		collection_total: number;
		score: number;
		rank: number;
		tags: any[];
	};
	_subcategory?: string;
}

const mgItems: MgItem[] = customBangumi
	.filter((item) => ["anime", "game", "real"].includes(item.data.category))
	.map((item) => {
		const { data, id } = item;
		const imageSrc =
			typeof data.image === "string" ? data.image : data.image.src;

		const finalLink = "/bangumi/" + removeFileExtension(id) + "/";

		const subjectTypeMap: Record<string, number> = {
			anime: 2,
			game: 4,
			real: 6,
		};

		const subcategory = (data as any).subcategory as string | undefined;

		return {
			subject_id: 0,
			subject_type: subjectTypeMap[data.category] || 2,
			rate: data.score || 0,
			type: data.status,
			comment: data.comment || null,
			tags: data.tags || [],
			ep_status: 0,
			vol_status: 0,
			updated_at: data.published?.toISOString() || new Date().toISOString(),
			private: false,
			link: finalLink,
			_subcategory: subcategory,
			subject: {
				id: 0,
				type: subjectTypeMap[data.category] || 2,
				name: data.title,
				name_cn: data.name_cn || data.title,
				short_summary: "",
				images: {
					medium: imageSrc,
					large: imageSrc,
					common: imageSrc,
					small: imageSrc,
					grid: imageSrc,
				},
				volumes: 0,
				eps: 0,
				collection_total: 0,
				score: data.score || 0,
				rank: 0,
				tags: [],
			},
		};
	})
	.sort(
		(a, b) =>
			new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime(),
	);

function getItemSubcategory(item: MgItem): string {
	if (item._subcategory) return item._subcategory;
	const tags = item.tags || [];
	if (tags.some((t: string) => t.includes("纪录"))) return "documentary";
	if (tags.some((t: string) => t.includes("动漫") || t.includes("动画")))
		return "anime";
	if (tags.some((t: string) => t.includes("电视剧") || t.includes("剧集")))
		return "tv";
	return "movie";
}

type TabKey = "all" | "movie" | "tv" | "anime" | "documentary" | "game";

const tabConfig: { key: TabKey; i18nKey: I18nKey }[] = [
	{ key: "all", i18nKey: I18nKey.moviesGamesTabAll },
	{ key: "movie", i18nKey: I18nKey.moviesGamesTabMovie },
	{ key: "tv", i18nKey: I18nKey.moviesGamesTabTV },
	{ key: "anime", i18nKey: I18nKey.moviesGamesTabAnime },
	{ key: "documentary", i18nKey: I18nKey.moviesGamesTabDocumentary },
	{ key: "game", i18nKey: I18nKey.moviesGamesTabGame },
];

interface SectionData {
	tabKey: string;
	tabName: string;
	tabCount: number;
	items: MgItem[];
	filters: { value: string; label: string; count: number }[];
}

const sections: SectionData[] = [];

for (const tc of tabConfig) {
	const items =
		tc.key === "all"
			? mgItems
			: mgItems.filter((item) => {
					if (tc.key === "game") return item.subject_type === 4;
					if (item.subject_type === 4) return false;
					return getItemSubcategory(item) === tc.key;
				});

	// 移除 items.length === 0 的过滤，确保后台数据能显示

	const statusCounts: Record<string, number> = {};
	for (const item of items) {
		const s = statusMap[item.type] || "unknown";
		statusCounts[s] = (statusCounts[s] || 0) + 1;
	}

	const filters = [
		{
			value: "all",
			label: i18n(I18nKey.bangumiFilterAll),
			count: items.length,
		},
		{
			value: "collect",
			label: i18n(I18nKey.bangumiFilterWatched),
			count: statusCounts.collect || 0,
		},
		{
			value: "doing",
			label: i18n(I18nKey.bangumiFilterWatching),
			count: statusCounts.doing || 0,
		},
		{
			value: "wish",
			label: i18n(I18nKey.bangumiFilterWish),
			count: statusCounts.wish || 0,
		},
		{
			value: "on_hold",
			label: i18n(I18nKey.bangumiFilterOnHold),
			count: statusCounts.on_hold || 0,
		},
		{
			value: "dropped",
			label: i18n(I18nKey.bangumiFilterDropped),
			count: statusCounts.dropped || 0,
		},
	];

	sections.push({
		tabKey: tc.key,
		tabName: i18n(tc.i18nKey),
		tabCount: items.length,
		items,
		filters,
	});
}

const activeTab = sections[0]?.tabKey || "all";

// 转换为 BangumiEditor 可用的初始数据
const subjectTypeToCategory: Record<number, string> = { 2: "anime", 4: "game", 6: "real" };
const bangumiInitialItems = mgItems.map((item) => ({
	id: String(item.subject_id || item.link),
	title: item.subject.name,
	name_cn: item.subject.name_cn || item.subject.name,
	category: subjectTypeToCategory[item.subject_type] || "anime",
	status: item.type,
	score: item.rate || 0,
	image: item.subject.images?.medium || "",
	tags: item.tags || [],
	comment: item.comment || "",
	updated_at: item.updated_at,
}));
---

<MainGridLayout title={i18n(I18nKey.moviesGamesTitle)} description={i18n(I18nKey.moviesGamesSubtitle)}>
	<div class="mg-page-wrapper flex w-full overflow-hidden relative min-h-32">
		<div data-pagefind-body class="card-base z-10 px-6 pt-8 pb-8 relative w-full">
			<!-- Page header -->
			<header class="mg-header relative w-full mb-8 flex justify-between items-start gap-4 flex-wrap">
				<div class="flex-1 min-w-0">
					<div class="flex items-center gap-3 mb-4">
						<div class="mg-icon flex items-center justify-center w-12 h-12 rounded-2xl bg-[var(--primary)]/10 dark:bg-[var(--primary)]/15 border border-[var(--primary)]/20 shadow-sm">
							<Icon name="material-symbols:movie-outline-rounded" class="text-[1.4rem] text-[var(--primary)]" />
						</div>
						<div>
							<h1 data-pagefind-meta="title" data-pagefind-weight="10" class="">
								{i18n(I18nKey.moviesGamesTitle)}
							</h1>
						</div>
					</div>
					<p class="text-sm text-[var(--content-meta)] leading-relaxed pl-[3.5rem]">
						{i18n(I18nKey.moviesGamesSubtitle)}
					</p>
					<p class="text-xs text-[var(--content-meta)] opacity-60 mt-1.5 pl-[3.5rem]">
						{i18n(I18nKey.bangumiLastUpdated)} {buildTime}
					</p>
				</div>
				<div class="page-header-toolbar-slot flex-shrink-0"></div>
			</header>

			<div data-no-swup>
				<BangumiEditor
					client:only
					defaultCategory="all"
					skipDomCollect={true}
					customPageName="影视游戏"
					initialItems={bangumiInitialItems}
				/>
			</div>

			<div class="bangumi-section">
			{mgItems.length > 0 ? (
				<>
					<!-- Tab Navigation -->
					<div class="mg-tabs-wrapper mb-6">
						<nav class="tools-tab-pill" data-mg-tab-nav aria-label="Tabs">
							<div class="tools-tab-indicator" data-mg-tab-indicator></div>
							{sections.map((sec) => (
								<button
									class:list={[
										"tools-tab-btn",
										sec.tabKey === activeTab
											? "tools-tab-btn-active"
											: "tools-tab-btn-inactive",
									]}
									data-tab={sec.tabKey}
									type="button"
								>
									<span>{sec.tabName}</span>
									<span class="tools-tab-badge">{sec.tabCount}</span>
								</button>
							))}
						</nav>
					</div>

					<!-- Sections -->
					{sections.map((sec) => (
						<div class:list={["mg-section", { "hidden": sec.tabKey !== activeTab }]} data-section={sec.tabKey}>
							{sec.items.length > 0 ? (
								<>
									<!-- Filters -->
									<div class="mg-filter-wrapper tools-tab-pill mb-5" data-mg-filter-nav={sec.tabKey}>
										<div class="tools-tab-indicator" data-mg-filter-indicator={sec.tabKey}></div>
										{sec.filters.map((filter) => (
											<button
												class:list={[
													"tools-tab-btn mg-filter-btn",
													filter.value === "all"
														? "tools-tab-btn-active"
														: "tools-tab-btn-inactive",
												]}
												data-filter={filter.value}
												data-section={sec.tabKey}
												type="button"
											>
												<span>{filter.label}</span>
												<span class="tools-tab-badge">{filter.count}</span>
											</button>
										))}
									</div>

									<!-- Grid -->
									<div class="mg-grid grid grid-cols-3 sm:grid-cols-4 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 md:gap-5">
										{sec.items.map((item: MgItem) => (
											<div
												class="mg-item"
												data-item-section={sec.tabKey}
												data-item-status={statusMap[item.type] || "unknown"}
											>
												<MovieGameCard item={item as any} link={item.link} />
											</div>
										))}
									</div>

									<ClientPagination
										totalItems={sec.items.length}
										itemsPerPage={12}
										itemsPerPageMobile={6}
										currentPage={1}
										sectionId={sec.tabKey}
									/>
								</>
							) : (
								<div class="flex flex-col items-center justify-center py-16 text-center">
									<p class="text-sm text-[var(--content-meta)]">{i18n(I18nKey.moviesGamesNoData)}</p>
								</div>
							)}
						</div>
					))}
				</>
			) : (
				<div class="flex flex-col items-center justify-center py-20 text-center">
					<div class="inline-flex items-center justify-center w-14 h-14 bg-[var(--btn-regular-bg)] rounded-2xl mb-4 border border-[var(--line-divider)]">
						<Icon name="material-symbols:movie-outline" class="w-7 h-7 text-[var(--content-meta)]" />
					</div>
					<h3 class="text-base font-medium text-[var(--deep-text)] dark:text-[var(--title-active)] mb-1.5">
						{i18n(I18nKey.moviesGamesNoData)}
					</h3>
				</div>
			)}
			</div>
		</div>
	</div>
<Comment customPath="/movies-games/" />

<script is:inline>
	(function() {
		function updateIndicator(indicator, btn) {
			if (!indicator || !btn) return;
			indicator.style.left = btn.offsetLeft + 'px';
			indicator.style.top = btn.offsetTop + 'px';
			indicator.style.width = btn.offsetWidth + 'px';
			indicator.style.height = btn.offsetHeight + 'px';
			indicator.style.opacity = '1';
		}

		function activateBtn(btns, target, indicator) {
			btns.forEach(function(btn) {
				btn.classList.remove('tools-tab-btn-active');
				btn.classList.add('tools-tab-btn-inactive');
				btn.disabled = false;
			});
			target.classList.remove('tools-tab-btn-inactive');
			target.classList.add('tools-tab-btn-active');
			target.disabled = true;
			if (indicator) {
				requestAnimationFrame(function() { updateIndicator(indicator, target); });
			}
		}

		function initIndicators() {
			var tabNav = document.querySelector('[data-mg-tab-nav]');
			var tabIndicator = document.querySelector('[data-mg-tab-indicator]');
			if (tabNav && tabIndicator) {
				var activeTab = tabNav.querySelector('.tools-tab-btn-active');
				if (activeTab) requestAnimationFrame(function() { updateIndicator(tabIndicator, activeTab); });
			}
			document.querySelectorAll('[data-mg-filter-indicator]').forEach(function(indicator) {
				var section = indicator.getAttribute('data-mg-filter-indicator');
				var nav = document.querySelector('[data-mg-filter-nav="' + section + '"]');
				if (nav) {
					var activeFilter = nav.querySelector('.tools-tab-btn-active');
					if (activeFilter) requestAnimationFrame(function() { updateIndicator(indicator, activeFilter); });
				}
			});
		}

		initIndicators();
		document.addEventListener('astro:page-load', initIndicators);
		document.addEventListener('swup:content:replace', function() { setTimeout(initIndicators, 50); });
		window.addEventListener('resize', initIndicators);

		document.addEventListener('click', function(e) {
			var tab = e.target.closest('[data-tab]');
			if (tab) {
				var targetTab = tab.dataset.tab;
				var tabNav = tab.closest('[data-mg-tab-nav]');
				var tabIndicator = tabNav ? tabNav.querySelector('[data-mg-tab-indicator]') : null;
				activateBtn(Array.from(tabNav.querySelectorAll('[data-tab]')), tab, tabIndicator);
				document.querySelectorAll('[data-section]').forEach(function(section) {
					section.classList.toggle('hidden', section.dataset.section !== targetTab);
				});
				// 初始化新 section 的筛选指示器
				var newFilterIndicator = document.querySelector('[data-mg-filter-indicator="' + targetTab + '"]');
				var newFilterNav = document.querySelector('[data-mg-filter-nav="' + targetTab + '"]');
				if (newFilterIndicator && newFilterNav) {
					var activeFilter = newFilterNav.querySelector('.tools-tab-btn-active');
					if (activeFilter) {
						// 强制重置指示器位置
						newFilterIndicator.style.opacity = '0';
						requestAnimationFrame(function() {
							updateIndicator(newFilterIndicator, activeFilter);
						});
					}
				}
				return;
			}

			var filterBtn = e.target.closest('.mg-filter-btn');
			if (filterBtn) {
				var filter = filterBtn.dataset.filter;
				var sid = filterBtn.dataset.section;
				var filterNav = filterBtn.closest('[data-mg-filter-nav]');
				var filterIndicator = filterNav ? filterNav.querySelector('[data-mg-filter-indicator]') : null;
				activateBtn(Array.from(filterNav.querySelectorAll('.mg-filter-btn')), filterBtn, filterIndicator);
				document.querySelectorAll('[data-item-section="' + sid + '"]').forEach(function(item) {
					var match = filter === 'all' || item.dataset.itemStatus === filter;
					item.classList.toggle('hidden', !match);
					item.style.display = match ? 'block' : 'none';
				});
				var pagination = document.querySelector('[data-pagination-section="' + sid + '"]');
				if (pagination) {
					var visibleItems = document.querySelectorAll('[data-item-section="' + sid + '"]:not(.hidden)');
					pagination.dispatchEvent(new CustomEvent('updatePagination', {
						detail: { visibleCount: visibleItems.length }
					}));
				}
			}
		});
	})();
</script>

<!-- 从 Gist 加载外部影视数据 -->
<script is:inline
  data-gist={externalBangumiConfig.gistId || ""}
  data-file={externalBangumiConfig.fileName || "bangumi.json"}>
  (function() {
    var _s = document.currentScript;
    var GIST_ID = _s.getAttribute("data-gist");
    var FILE_NAME = _s.getAttribute("data-file");
    if (!GIST_ID) return;

    var cacheKey = "__externalBangumiCache";

    var statusMap = { 1: "wish", 2: "collect", 3: "doing", 4: "on_hold", 5: "dropped" };
    var statusText = { 1: "想看", 2: "看过", 3: "在看", 4: "搁置", 5: "抛弃" };
    var statusColor = { 1: "bg-sky-500/80", 2: "bg-emerald-500/80", 3: "bg-amber-500/80", 4: "bg-violet-500/80", 5: "bg-rose-400/80" };

    // 分类映射：Gist 中的 category → 页面中的 section key
    function getSectionKey(item) {
      var cat = item.category || "movie";
      var validSections = ["movie", "tv", "anime", "documentary", "game"];
      return validSections.indexOf(cat) !== -1 ? cat : "movie";
    }

    function esc(t) { var d = document.createElement("div"); d.textContent = t; return d.innerHTML; }

    function createCard(item) {
      var title = item.name_cn || item.title || "";
      var image = item.image || "";
      var score = item.score || 0;
      var status = item.status || 2;
      var tags = item.tags || [];
      var comment = item.comment || "";

      var imgHtml = image
        ? '<img src="' + esc(image) + '" alt="' + esc(title) + '" class="mg-img" loading="lazy" />'
        : '<div class="mg-img" style="background:var(--btn-regular-bg);display:flex;align-items:center;justify-content:center;font-size:2rem;">🎬</div>';

      var scoreHtml = score > 0
        ? '<span class="mg-score"><svg class="mg-star" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>' + score + '</span>'
        : '';

      var tagsHtml = '';
      if (tags.length > 0) {
        tagsHtml = '<div class="mg-tags">';
        tags.slice(0, 3).forEach(function(t) { tagsHtml += '<span class="mg-tag">' + esc(t) + '</span>'; });
        tagsHtml += '</div>';
      }

      var commentHtml = comment
        ? '<div class="mg-overlay"><p class="mg-comment">' + esc(comment) + '</p></div>'
        : '';

      var a = document.createElement("a");
      a.href = "#";
      a.className = "mg-card group";
      a.setAttribute("data-ext-bangumi", "1");

      a.innerHTML =
        '<div class="mg-cover">' +
        imgHtml +
        '<div class="mg-gradient"></div>' +
        '<span class="mg-status ' + (statusColor[status] || 'bg-gray-500/80') + '">' + esc(statusText[status] || '未知') + '</span>' +
        scoreHtml +
        '<div class="mg-info"><h3 class="mg-title">' + esc(title) + '</h3>' + tagsHtml + '</div>' +
        commentHtml +
        '</div>';

      return a;
    }

    function insertBangumi(items) {
      // 全局标记防止重复插入（Swup 可能多次触发）
      if (window.__bangumiInserted) return;
      if (document.querySelector('[data-ext-bangumi]')) return;
      window.__bangumiInserted = true;

      var enabledItems = items;
      if (!enabledItems.length) return;

      // 按更新时间排序（新的在前）
      enabledItems.sort(function(a, b) {
        return new Date(b.updated_at || 0) - new Date(a.updated_at || 0);
      });

      // 按分类分组
      var groups = {};
      enabledItems.forEach(function(item) {
        var key = getSectionKey(item);
        if (!groups[key]) groups[key] = [];
        groups[key].push(item);
      });

      // 获取本地卡片的更新时间用于排序插入
      function getLocalCardDate(card) {
        var dateAttr = card.getAttribute("data-ext-date");
        if (dateAttr) return new Date(dateAttr);
        return new Date(0);
      }

      // 插入到对应的 section grid 中（按时间排序）
      Object.keys(groups).forEach(function(sectionKey) {
        var section = document.querySelector('[data-section="' + sectionKey + '"]');
        if (!section) return;
        var grid = section.querySelector('.mg-grid');
        if (!grid) return;

        var localCards = Array.from(grid.querySelectorAll('.mg-item'));

        groups[sectionKey].forEach(function(item) {
          var extDate = new Date(item.updated_at || 0);
          var wrapper = document.createElement("div");
          wrapper.className = "mg-item";
          wrapper.setAttribute("data-item-section", sectionKey);
          wrapper.setAttribute("data-item-status", statusMap[item.status] || "unknown");
          wrapper.setAttribute("data-ext-bangumi", "1");
          wrapper.appendChild(createCard(item));

          var inserted = false;
          for (var i = 0; i < localCards.length; i++) {
            var localDate = getLocalCardDate(localCards[i]);
            if (extDate > localDate) {
              grid.insertBefore(wrapper, localCards[i]);
              inserted = true;
              break;
            }
          }
          if (!inserted) {
            grid.appendChild(wrapper);
          }
        });

        // 更新该 section 的 tab 计数
        var tabBtn = document.querySelector('[data-tab="' + sectionKey + '"] .tools-tab-badge');
        if (tabBtn) {
          var currentCount = parseInt(tabBtn.textContent) || 0;
          tabBtn.textContent = currentCount + groups[sectionKey].length;
        }

        // 更新该 section 的筛选按钮计数
        var filterBtns = section.querySelectorAll('.mg-filter-btn');
        var statusCounts = { all: groups[sectionKey].length };
        groups[sectionKey].forEach(function(item) {
          var s = statusMap[item.status] || "unknown";
          statusCounts[s] = (statusCounts[s] || 0) + 1;
        });
        filterBtns.forEach(function(btn) {
          var filterVal = btn.getAttribute("data-filter");
          var badge = btn.querySelector('.tools-tab-badge');
          if (badge && statusCounts[filterVal]) {
            var cur = parseInt(badge.textContent) || 0;
            badge.textContent = cur + statusCounts[filterVal];
          }
        });
      });

      // 也插入到 "all" section
      var allSection = document.querySelector('[data-section="all"]');
      if (allSection) {
        var allGrid = allSection.querySelector('.mg-grid');
        if (allGrid) {
          var allLocalCards = Array.from(allGrid.querySelectorAll('.mg-item'));

          enabledItems.forEach(function(item) {
            var extDate = new Date(item.updated_at || 0);
            var wrapper = document.createElement("div");
            wrapper.className = "mg-item";
            wrapper.setAttribute("data-item-section", "all");
            wrapper.setAttribute("data-item-status", statusMap[item.status] || "unknown");
            wrapper.setAttribute("data-ext-bangumi", "1");
            wrapper.appendChild(createCard(item));

            var inserted = false;
            for (var i = 0; i < allLocalCards.length; i++) {
              var localDate = getLocalCardDate(allLocalCards[i]);
              if (extDate > localDate) {
                allGrid.insertBefore(wrapper, allLocalCards[i]);
                inserted = true;
                break;
              }
            }
            if (!inserted) {
              allGrid.appendChild(wrapper);
            }
          });

          // 更新 "all" tab 计数
          var allTabBtn = document.querySelector('[data-tab="all"] .tools-tab-badge');
          if (allTabBtn) {
            var currentAllCount = parseInt(allTabBtn.textContent) || 0;
            allTabBtn.textContent = currentAllCount + enabledItems.length;
          }

          // 更新 "all" section 的筛选按钮计数
          var allFilterBtns = allSection.querySelectorAll('.mg-filter-btn');
          var allStatusCounts = { all: enabledItems.length };
          enabledItems.forEach(function(item) {
            var s = statusMap[item.status] || "unknown";
            allStatusCounts[s] = (allStatusCounts[s] || 0) + 1;
          });
          allFilterBtns.forEach(function(btn) {
            var filterVal = btn.getAttribute("data-filter");
            var badge = btn.querySelector('.tools-tab-badge');
            if (badge && allStatusCounts[filterVal]) {
              var cur = parseInt(badge.textContent) || 0;
              badge.textContent = cur + allStatusCounts[filterVal];
            }
          });
        }
      }
    }

    function fetchBangumi() {
      if (window[cacheKey] && window[cacheKey].time > Date.now() - 300000) {
        insertBangumi(window[cacheKey].data);
        return;
      }

      fetch("https://api.github.com/gists/" + GIST_ID, {
        headers: { "Accept": "application/vnd.github+json" }
      })
        .then(function(r) { if (!r.ok) throw new Error("HTTP " + r.status); return r.json(); })
        .then(function(gist) {
          var file = gist.files[FILE_NAME];
          if (!file) return;
          var data = [];
          try { data = JSON.parse(file.content || "[]"); } catch(e) { return; }
          if (!Array.isArray(data) || !data.length) return;
          window[cacheKey] = { data: data, time: Date.now() };
          insertBangumi(data);
        })
        .catch(function(e) { console.warn("[外部影视] 加载失败:", e.message); });
    }

    fetchBangumi();
    document.addEventListener("swup:content:replace", function() { setTimeout(fetchBangumi, 50); });
    document.addEventListener("astro:page-load", function() { fetchBangumi(); });
  })();
</script>
</MainGridLayout>

