---
import Icon from "@components/common/Icon.astro";
import AlbumCard from "@/components/pages/gallery/AlbumCard.astro";
import NetworkAlbum from "@/components/pages/gallery/NetworkAlbum.svelte";
import { galleryConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getAlbumCover, scanAlbumPhotos } from "@/utils/gallery-utils";

if (!siteConfig.pages.gallery) {
	return Astro.redirect("/404/");
}

const title = i18n(I18nKey.gallery);
const description = i18n(I18nKey.galleryDescription);

const albums = galleryConfig.albums.map((album) => {
	const photos = scanAlbumPhotos(album.id);
	const cover = getAlbumCover(album, photos);
	return { ...album, cover, photoCount: photos.length };
});

const allTags = [...new Set(albums.flatMap((a) => a.tags || []))].sort();

const tabs = [
	{
		id: "local",
		name: i18n(I18nKey.galleryLocalAlbum),
		icon: "material-symbols:folder-rounded",
	},
	{
		id: "network",
		name: i18n(I18nKey.galleryNetworkAlbum),
		icon: "material-symbols:wallpaper",
	},
];
---

<MainGridLayout title={title} description={description}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <div class="mb-4">
        <div class="flex items-center gap-3 mb-3">
          <Icon name="material-symbols:photo-library" class="text-[1.875rem]" />
          <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            {title}
          </div>
        </div>
        {description && (
          <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">
            {description}
          </p>
        )}
      </div>

      <div class="border-b border-(--line-divider) mb-3 relative">
        <div class="overflow-x-auto" data-tab-scroll-container>
          <nav class="flex min-w-max space-x-8" aria-label="Gallery Tabs" data-gallery-tab-nav>
            <div class="gallery-tab-indicator" data-gallery-tab-indicator></div>
            {tabs.map((tab) => (
              <button
                class:list={[
                  "gallery-tab-btn whitespace-nowrap py-4 px-1 font-medium text-sm transition-colors duration-200 flex items-center gap-2",
                  {
                    "gallery-tab-btn-active": tab.id === "local",
                    "gallery-tab-btn-inactive": tab.id !== "local"
                  }
                ]}
                data-gallery-tab={tab.id}
                type="button"
              >
                <Icon name={tab.icon} class="text-[1.1rem]" />
                {tab.name}
              </button>
            ))}
          </nav>
        </div>
      </div>

      <div data-gallery-section="local">
        {albums.length > 0 && allTags.length > 0 && (
          <div class="tools-tab-wrapper">
            <gallery-filter class="tools-tab-pill" data-gallery-filter>
              <div class="tools-tab-indicator gallery-filter-indicator" style="opacity:0;"></div>
              <button
                data-tag="all"
                class="tools-tab-btn tools-tab-btn-active"
              >
                {i18n(I18nKey.all)}
              </button>
              {allTags.map((tag) => (
                <button
                  data-tag={tag}
                  class="tools-tab-btn tools-tab-btn-inactive"
                >
                  {tag}
                </button>
              ))}
            </gallery-filter>
          </div>
        )}

        {albums.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 my-4">
            {albums.map((album) => (
              <AlbumCard
                id={album.id}
                name={album.name}
                cover={album.cover}
                description={album.description}
                date={album.date}
                location={album.location}
                tags={album.tags}
                photoCount={album.photoCount}
              />
            ))}
          </div>
        ) : (
          <div class="flex flex-col items-center justify-center py-16 text-neutral-400 dark:text-neutral-500">
            <Icon name="material-symbols:photo-library" class="text-6xl mb-4 opacity-50" />
            <p class="text-lg">{i18n(I18nKey.galleryNoAlbums)}</p>
          </div>
        )}
      </div>

      <div data-gallery-section="network" class="hidden">
        <NetworkAlbum client:visible />
      </div>
    </div>
  </div>

  <style>
    [data-gallery-tab-nav] {
      position: relative;
    }

    .gallery-tab-indicator {
      position: absolute;
      bottom: 0;
      height: 2px;
      background: black;
      transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1), width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 1;
      pointer-events: none;
    }

    :root.dark .gallery-tab-indicator {
      background: white;
    }

    .gallery-tab-btn {
      position: relative;
      z-index: 2;
      background: transparent;
      border: none;
      cursor: pointer;
      color: #6b7280;
      border-bottom: 2px solid transparent;
    }

    :root.dark .gallery-tab-btn {
      color: #9ca3af;
    }

    .gallery-tab-btn:hover {
      color: #374151;
    }

    :root.dark .gallery-tab-btn:hover {
      color: #d1d5db;
    }

    .gallery-tab-btn-active {
      color: black;
    }

    :root.dark .gallery-tab-btn-active {
      color: white;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .gallery-card-fade-in {
      animation: fadeInUp 0.35s ease-out both;
    }
  </style>

  <script slot="head" is:inline>
    (function() {
      function initGalleryTabs() {
        const tabButtons = document.querySelectorAll('[data-gallery-tab]');
        const sections = document.querySelectorAll('[data-gallery-section]');
        const indicator = document.querySelector('[data-gallery-tab-indicator]');

        function updateIndicator(targetBtn) {
          if (!indicator || !targetBtn) return;
          const nav = targetBtn.closest('[data-gallery-tab-nav]');
          if (!nav) return;
          const navRect = nav.getBoundingClientRect();
          const btnRect = targetBtn.getBoundingClientRect();
          indicator.style.left = (btnRect.left - navRect.left) + 'px';
          indicator.style.width = btnRect.width + 'px';
          indicator.style.opacity = '1';
        }

        function activateTab(targetTab) {
          if (!targetTab) return;

          const targetButton = Array.from(tabButtons).find(
            (btn) => btn.dataset.galleryTab === targetTab
          );
          if (!targetButton) return;

          tabButtons.forEach((btn) => {
            btn.classList.remove('gallery-tab-btn-active');
            btn.classList.add('gallery-tab-btn-inactive');
          });

          targetButton.classList.remove('gallery-tab-btn-inactive');
          targetButton.classList.add('gallery-tab-btn-active');

          updateIndicator(targetButton);

          sections.forEach((section) => {
            if (section.dataset.gallerySection === targetTab) {
              section.classList.remove('hidden');
            } else {
              section.classList.add('hidden');
            }
          });

          const nextHash = '#gallery-' + encodeURIComponent(targetTab);
          if (window.location.hash !== nextHash) {
            window.history.replaceState(null, '', nextHash);
          }
        }

        tabButtons.forEach((button) => {
          button.addEventListener('click', (event) => {
            const currentButton = event.currentTarget;
            const targetTab = currentButton.dataset.galleryTab;
            if (targetTab) {
              activateTab(targetTab);
            }
          });
        });

        function getTabFromHash() {
          const hash = window.location.hash.replace(/^#gallery-/, '');
          if (!hash) return '';
          try {
            return decodeURIComponent(hash);
          } catch {
            return '';
          }
        }

        const initialTab = getTabFromHash();
        if (initialTab) {
          activateTab(initialTab);
        } else {
          const activeBtn = document.querySelector('.gallery-tab-btn-active');
          if (activeBtn) {
            requestAnimationFrame(() => {
              updateIndicator(activeBtn);
            });
          }
        }

        window.addEventListener('hashchange', () => {
          const tabFromHash = getTabFromHash();
          if (tabFromHash) {
            activateTab(tabFromHash);
          }
        });

        window.addEventListener('resize', () => {
          const activeBtn = document.querySelector('.gallery-tab-btn-active');
          if (activeBtn) {
            updateIndicator(activeBtn);
          }
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initGalleryTabs);
      } else {
        initGalleryTabs();
      }

      document.addEventListener("astro:page-load", initGalleryTabs);
      document.addEventListener("astro:after-swap", initGalleryTabs);
    })();
  </script>

  <script slot="head" is:inline>
    (function() {
      function initGalleryFilter() {
        const filterEl = document.querySelector("gallery-filter");
        if (!filterEl) return;

        const allBtn = filterEl.querySelector('button[data-tag="all"]');
        const indicator = filterEl.querySelector(".gallery-filter-indicator");
        if (!allBtn || !indicator) return;

        // 初始化指示器位置
        indicator.style.left = allBtn.offsetLeft + "px";
        indicator.style.top = allBtn.offsetTop + "px";
        indicator.style.width = allBtn.offsetWidth + "px";
        indicator.style.height = allBtn.offsetHeight + "px";
        indicator.style.opacity = "1";
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initGalleryFilter);
      } else {
        initGalleryFilter();
      }

      document.addEventListener("astro:page-load", initGalleryFilter);
      document.addEventListener("astro:after-swap", initGalleryFilter);
    })();

    if (!customElements.get("gallery-filter")) {
      class GalleryFilter extends HTMLElement {
        constructor() {
          super();
        }

        connectedCallback() {
          this.addEventListener("click", this.handleClick);
        }

        disconnectedCallback() {
          this.removeEventListener("click", this.handleClick);
        }

        updateIndicator(button) {
          if (!button) return;
          const indicator = this.querySelector(".gallery-filter-indicator");
          if (!indicator) return;

          indicator.style.left = button.offsetLeft + "px";
          indicator.style.top = button.offsetTop + "px";
          indicator.style.width = button.offsetWidth + "px";
          indicator.style.height = button.offsetHeight + "px";
          indicator.style.opacity = "1";
        }

        handleClick(e) {
          const target = e.target;
          const button = target.closest("button");
          if (!button) return;

          const selectedTag = button.dataset.tag;
          const filters = this.querySelectorAll("button");
          const container = this.closest(".card-base");
          if (!container) return;

          const cards = container.querySelectorAll(".album-card");

          // 切换激活态
          filters.forEach((f) => {
            f.classList.remove("tools-tab-btn-active");
            f.classList.add("tools-tab-btn-inactive");
            f.disabled = false;
          });
          button.classList.remove("tools-tab-btn-inactive");
          button.classList.add("tools-tab-btn-active");
          button.disabled = true;

          this.updateIndicator(button);

          // 过滤卡片
          cards.forEach((card) => {
            const cardEl = card;
            const tags = (cardEl.dataset.tags || "").split(",");
            if (
              selectedTag === "all" ||
              (selectedTag && tags.includes(selectedTag))
            ) {
              cardEl.style.display = "";
              cardEl.classList.remove("gallery-card-fade-in");
              void cardEl.offsetHeight;
              cardEl.classList.add("gallery-card-fade-in");
            } else {
              cardEl.style.display = "none";
              cardEl.classList.remove("gallery-card-fade-in");
            }
          });
        }
      }
      customElements.define("gallery-filter", GalleryFilter);
    }
  </script>
</MainGridLayout>
