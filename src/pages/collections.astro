---
import Icon from "@components/common/Icon.astro";
import { collectionsApiConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

if (!siteConfig.pages.collections) {
	return Astro.redirect("/404/");
}

const title = collectionsApiConfig.title || i18n(I18nKey.collections);
const description =
	collectionsApiConfig.description || i18n(I18nKey.collectionsDescription);
const enabledApis = collectionsApiConfig.apis.filter((api) => api.enabled);

// 提取分类
const categories = collectionsApiConfig.categories?.length
	? collectionsApiConfig.categories
	: [...new Set(enabledApis.map((api) => api.category))];
---

<MainGridLayout title={title} description={description}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题 -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-3">
          <Icon name="material-symbols:bookmark" class="text-[1.875rem]" />
          <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            {title}
          </div>
        </div>
        {description && (
          <p class="text-base text-neutral-500 dark:text-neutral-400 leading-relaxed">
            {description}
          </p>
        )}
      </div>

      <!-- API 列表：按分类分组 -->
      {enabledApis.length > 0 ? (
        categories.map((cat) => {
          const catApis = enabledApis.filter((api) => api.category === cat);
          if (catApis.length === 0) return null;
          return (
            <div class="category-group mt-10 first:mt-0">
              <!-- 分类头部：图标 + 名称 + 数量 + 分隔线 -->
              <div class="flex items-center gap-3 mb-6">
                <div class="flex items-center gap-2">
                  <Icon name="material-symbols:label-outline" class="text-lg text-neutral-900 dark:text-neutral-100" />
                  <span class="text-lg font-bold text-neutral-900 dark:text-neutral-100">{cat}</span>
                </div>
                <span class="text-xs text-neutral-400 dark:text-neutral-500">{catApis.length}</span>
                <div class="flex-1 h-[2px] bg-black dark:bg-white" />
              </div>

              <!-- 分类下的 API 卡片 -->
              <div class="api-grid">
                {catApis.map((api, index) => (
                  <a
                    href={api.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="api-card group"
                    data-category={api.category}
                    style={`animation-delay: ${index * 60}ms`}
                  >
                    <!-- 右上角跳转图标 -->
                    <div class="api-card-jump-icon">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M7 17L17 7" />
                        <path d="M7 7h10v10" />
                      </svg>
                    </div>

                    <!-- 顶部：图标 + 名称同行 -->
                    <div class="flex items-center gap-2 mb-3">
                      {api.icon ? (
                        api.icon.startsWith('http') ? (
                          <img src={api.icon} alt={api.name} class="w-6 h-6 rounded object-contain shrink-0" />
                        ) : (
                          <Icon name={api.icon} class="text-2xl text-neutral-600 dark:text-neutral-300 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 shrink-0" />
                        )
                      ) : (
                        <Icon name="material-symbols:api" class="text-2xl text-neutral-600 dark:text-neutral-300 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 shrink-0" />
                      )}
                      <h3 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 group-hover:translate-x-1 transition-transform duration-300 truncate">
                        {api.name}
                      </h3>
                    </div>

                    <!-- 描述 -->
                    <p class="api-card-desc">
                      {api.description}
                    </p>

                    <!-- 底部域名 -->
                    <div class="api-card-footer">
                      <span class="text-xs text-neutral-400 dark:text-neutral-500 truncate">
                        {new URL(api.url).hostname}
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          );
        })
      ) : (
        <div class="text-center py-16">
          <Icon name="material-symbols:bookmark-outline" class="text-5xl text-neutral-300 dark:text-neutral-600 mb-4" />
          <p class="text-neutral-500 dark:text-neutral-400">{i18n(I18nKey.collectionsEmpty)}</p>
        </div>
      )}
    </div>
  </div>
</MainGridLayout>

<style is:global>
  .api-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .api-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .api-grid {
      grid-template-columns: 1fr;
    }
  }

  .api-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    border-radius: var(--radius-large, 0.75rem);
    border: 2px solid #000;
    background: #fff;
    text-decoration: none;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
    animation: cardSlideIn 0.5s ease-out forwards;
    transition: border-color 300ms ease, box-shadow 300ms ease, transform 300ms ease, background-color 300ms ease;
  }

  :root.dark .api-card {
    border-color: #fff;
    background: #000;
  }

  .api-card:hover {
    border-color: #000;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    transform: translateY(-2px);
  }

  :root.dark .api-card:hover {
    border-color: #fff;
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }

  /* 右上角跳转图标 */
  .api-card-jump-icon {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.5rem;
    color: oklch(0.55 0 0);
    background: oklch(0.9 0 0);
    opacity: 0;
    transform: scale(0.8) translateY(-4px);
    transition: opacity 250ms cubic-bezier(0.4, 0, 0.2, 1),
                transform 250ms cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 2;
    pointer-events: none;
  }

  :root.dark .api-card-jump-icon {
    color: oklch(0.6 0 0);
    background: oklch(0.2 0 0);
  }

  .api-card:hover .api-card-jump-icon {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  /* 描述文本：固定高度 + 省略号 */
  .api-card-desc {
    margin: 0 0 0.75rem 0;
    font-size: 0.875rem;
    font-weight: 400;
    color: oklch(0.45 0 0);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
    min-height: 2.625rem;
  }

  :root.dark .api-card-desc {
    color: oklch(0.55 0 0);
  }

  /* 底部域名 */
  .api-card-footer {
    display: flex;
    align-items: center;
    padding-top: 0.75rem;
    border-top: 1px solid oklch(0.9 0 0);
    margin-top: auto;
  }

  :root.dark .api-card-footer {
    border-color: oklch(0.2 0 0);
  }

  @keyframes cardSlideIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
