---
import { Icon } from "astro-icon/components";
import Comment from "@/components/comment/index.astro";
import PageTitle from "@/components/common/PageTitle.astro";
import MomentsCover from "@/components/moments/MomentsCover.astro";
import MomentsEditor from "@/components/edit/MomentsEditor.svelte";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

import "@/styles/components/moment-card.css";
---

<MainGridLayout title="动态" description="记录生活中的点点滴滴">
  <!-- 微信朋友圈风格封面 -->
  <MomentsCover />

  <!-- 页面标题 -->
  <div class="mb-4 flex justify-between items-start gap-4 flex-wrap">
    <div class="flex-1 min-w-0">
      <PageTitle title="动态" eyebrow="Moments" variant="stacked" />
      <p class="text-base text-neutral-500 dark:text-neutral-400 leading-relaxed mt-3">记录生活中的点点滴滴</p>
    </div>
    <div class="page-header-toolbar-slot flex-shrink-0"></div>
  </div>

  <!-- 说说编辑器（Svelte 组件） -->
  <div data-no-swup>
    <MomentsEditor client:only />
  </div>

  <!-- 置顶说说（JS 动态填充） -->
  <div class="wx-pinned" id="pinned-block" style="display:none">
    <div class="wx-pinned-tag">
      <iconify-icon icon="material-symbols:push-pin"></iconify-icon>
      <span>置顶</span>
    </div>
    <div class="wx-pinned-items" id="pinned-items"></div>
  </div>

  <!-- 说说列表（JS 动态渲染） -->
  <div class="wx-feed" id="moments-feed">
    <div class="wx-loading" id="moments-loading">
      <iconify-icon icon="material-symbols:progress-activity-rounded" class="wx-loading-icon"></iconify-icon>
      <span>加载中...</span>
    </div>
  </div>

  <!-- 评论区 -->
  <div id="moments-comments">
    <Comment customPath="/moments/" />
  </div>

  <!-- 访客统计 -->
  <div class="wx-visitor">
    <Icon name="material-symbols:visibility-outline" class="wx-visitor-icon" />
    <span class="waline-count" data-path="/moments/">-</span>
    <span>次浏览</span>
  </div>
</MainGridLayout>

<script is:inline>
  // ========== 访客统计 ==========
  var countElements = document.querySelectorAll('.waline-count[data-path="/moments/"]');
  if (countElements.length > 0) {
    var serverURL = "https://co.tsh520.cn";
    fetch(serverURL + "/api/uv?path=/moments/")
      .then(function(res) { return res.json(); })
      .then(function(data) {
        var count = data.data ? data.data.unique_visitor || data.uv || 0 : (data.uv || 0);
        countElements.forEach(function(el) { el.textContent = String(count); });
      })
      .catch(function() {
        countElements.forEach(function(el) { el.textContent = "-"; });
      });
  }

  // ========== 说说客户端渲染 ==========
  var MOMENTS_JSON = "/moments.json";
  var DEFAULT_AVATAR = "https://q1.qlogo.cn/g?b=qq&nk=20447289&s=640";
  var DEFAULT_AUTHOR = "OLX";

  function escapeHtml(str) {
    if (!str) return "";
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function formatTimeAgo(dateStr) {
    var date = new Date(dateStr);
    if (isNaN(date.getTime())) return dateStr;
    var now = new Date();
    var diff = now.getTime() - date.getTime();
    var minutes = Math.floor(diff / 60000);
    var hours = Math.floor(diff / 3600000);
    var days = Math.floor(diff / 86400000);
    if (minutes < 1) return "刚刚";
    if (minutes < 60) return minutes + "分钟前";
    if (hours < 24) return hours + "小时前";
    if (days < 30) return days + "天前";
    var y = date.getFullYear();
    var m = String(date.getMonth() + 1).padStart(2, "0");
    var d = String(date.getDate()).padStart(2, "0");
    return y + "-" + m + "-" + d;
  }

  function getGridCols(count) {
    if (count === 1) return 1;
    if (count === 2 || count === 4) return 2;
    return 3;
  }

  function renderMomentCard(m) {
    var author = escapeHtml(m.author || DEFAULT_AUTHOR);
    var avatar = escapeHtml(m.avatar || DEFAULT_AVATAR);
    var content = escapeHtml(m.content || "").replace(/\n/g, "<br>");
    var time = formatTimeAgo(m.published);
    var isoTime = new Date(m.published).toISOString();

    // 卡片头部
    var pinnedBadge = m.pinned
      ? '<span class="pinned-badge"><iconify-icon icon="material-symbols:pinboard" class="pinned-icon"></iconify-icon><span>置顶</span></span>'
      : "";

    var locationHtml = m.location
      ? '<span class="meta-dot">·</span><span class="location"><iconify-icon icon="material-symbols:location-on-outline" class="location-icon"></iconify-icon>' + escapeHtml(m.location) + "</span>"
      : "";

    var header = '<div class="card-header">'
      + '<div class="card-avatar"><img src="' + avatar + '" alt="' + author + '" class="avatar-img" loading="lazy" onerror="this.src=\'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22%23999%22><circle cx=%2212%22 cy=%228%22 r=%224%22/><path d=%22M20 21a8 8 0 1 0-16 0%22/></svg>\'"></div>'
      + '<div class="card-user-info"><div class="user-row"><span class="user-name">' + author + "</span>" + pinnedBadge + "</div>"
      + '<div class="meta-row"><time datetime="' + isoTime + '">' + time + "</time>" + locationHtml + "</div></div></div>";

    // 内容
    var contentHtml = content
      ? '<div class="card-content"><div class="moment-markdown"><p>' + content + "</p></div></div>"
      : "";

    // 图片
    var imagesHtml = "";
    if (m.images && m.images.length > 0) {
      var cols = getGridCols(m.images.length);
      var imgItems = "";
      var maxShow = 9;
      for (var i = 0; i < m.images.length && i < maxShow; i++) {
        var img = escapeHtml(m.images[i]);
        var isLast = i === maxShow - 1 && m.images.length > maxShow;
        imgItems += '<div class="image-item">'
          + '<img src="' + img + '" alt="" class="image-img" loading="lazy" data-fancybox="gallery-' + escapeHtml(m.id) + '" data-src="' + img + '">'
          + (isLast ? '<div class="more-overlay"><span class="more-text">+' + (m.images.length - maxShow + 1) + "</span></div>" : "")
          + "</div>";
      }
      imagesHtml = '<div class="card-images image-cols-' + cols + '">' + imgItems + "</div>";
    }

    // 标签
    var tagsHtml = "";
    if (m.tags && m.tags.length > 0) {
      var tagItems = "";
      for (var j = 0; j < m.tags.length; j++) {
        var tag = escapeHtml(m.tags[j].trim());
        if (tag) tagItems += '<a href="/tags/' + encodeURIComponent(tag) + '/" class="tag-item">#' + tag + "</a>";
      }
      tagsHtml = '<div class="card-tags">' + tagItems + "</div>";
    }

    return '<div class="wx-feed-item" data-published="' + isoTime + '">'
      + '<div id="' + escapeHtml(m.id) + '" class="moment-card group">'
      + '<div class="card-accent-bar"></div>'
      + header + contentHtml + imagesHtml + tagsHtml
      + "</div></div>";
  }

  function renderPinnedBlock(pinned) {
    var block = document.getElementById("pinned-block");
    var container = document.getElementById("pinned-items");
    if (!block || !container) return;

    if (pinned.length === 0) {
      block.style.display = "none";
      return;
    }

    block.style.display = "";
    var html = "";
    for (var i = 0; i < pinned.length; i++) {
      var m = pinned[i];
      if (m.images && m.images.length > 0) {
        var cols = Math.min(m.images.length, 9);
        var imgs = "";
        for (var j = 0; j < cols; j++) {
          imgs += '<img src="' + escapeHtml(m.images[j]) + '" alt="" class="wx-pinned-img" loading="lazy">';
        }
        html += '<div class="wx-pinned-preview"><div class="wx-pimgs wx-pimgs-' + cols + '">' + imgs + "</div></div>";
      } else {
        var text = (m.content || "").slice(0, 60);
        if ((m.content || "").length > 60) text += "...";
        html += '<div class="wx-pinned-preview"><p class="wx-ptxt">' + escapeHtml(text) + "</p></div>";
      }
    }
    container.innerHTML = html;
  }

  function renderMoments() {
    var feed = document.getElementById("moments-feed");
    if (!feed) return;

    fetch(MOMENTS_JSON + "?t=" + Date.now())
      .then(function(res) {
        if (!res.ok) throw new Error("HTTP " + res.status);
        return res.json();
      })
      .then(function(data) {
        if (!Array.isArray(data)) data = [];

        // 分离置顶和普通
        var pinned = [];
        var normal = [];
        for (var i = 0; i < data.length; i++) {
          if (data[i].pinned) pinned.push(data[i]);
          else normal.push(data[i]);
        }

        // 按时间倒序
        pinned.sort(function(a, b) { return new Date(b.published) - new Date(a.published); });
        normal.sort(function(a, b) { return new Date(b.published) - new Date(a.published); });

        // 渲染置顶
        renderPinnedBlock(pinned);

        // 渲染列表（置顶在前）
        var all = pinned.concat(normal);
        if (all.length === 0) {
          feed.innerHTML = '<div class="wx-empty" id="moments-empty">'
            + '<div class="wx-empty-icon"><iconify-icon icon="material-symbols:sentiment-neutral-outline"></iconify-icon></div>'
            + "<h3>还没有发布任何说说</h3>"
            + "<p>快去记录你的生活点滴吧</p></div>";
          return;
        }

        var html = "";
        for (var j = 0; j < all.length; j++) {
          html += renderMomentCard(all[j]);
        }
        feed.innerHTML = html;

        // 确保 iconify 加载图标
        if (window.Iconify && window.Iconify.scan) {
          window.Iconify.scan(feed);
          var pinnedBlock = document.getElementById("pinned-block");
          if (pinnedBlock) window.Iconify.scan(pinnedBlock);
        }
      })
      .catch(function(err) {
        console.error("[Moments] Failed to load:", err);
        feed.innerHTML = '<div class="wx-empty"><div class="wx-empty-icon"><iconify-icon icon="material-symbols:error-outline"></iconify-icon></div>'
          + "<h3>加载失败</h3><p>请稍后刷新页面重试</p></div>";
      });
  }

  // 页面加载后渲染
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", renderMoments);
  } else {
    renderMoments();
  }
</script>

<style>
  /* ============================================
   * 说说列表（页面级样式）
   * ============================================ */
  .wx-feed {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem 0 2rem;
  }

  .wx-feed-item {
    position: relative;
  }

  .wx-feed-item + .wx-feed-item::before {
    content: '';
    position: absolute;
    top: -0.75rem;
    left: 1rem;
    right: 1rem;
    height: 1px;
    background: var(--border);
    opacity: 0.7;
  }

  /* 加载状态 */
  .wx-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 3rem 1rem;
    color: var(--content-meta);
    font-size: 0.875rem;
  }

  .wx-loading-icon {
    font-size: 1.25rem;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* 空状态 */
  .wx-empty {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .wx-empty-icon {
    width: 4rem;
    height: 4rem;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--btn-regular-bg);
    border-radius: 50%;
    color: var(--content-meta);
    font-size: 2rem;
  }

  .wx-empty h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 0.375rem;
  }

  .wx-empty p {
    font-size: 0.875rem;
    color: var(--content-meta);
    margin: 0;
  }

  /* 访客统计 */
  .wx-visitor {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    margin: 1.5rem auto 0;
    padding: 0.75rem;
    color: var(--content-meta);
    font-size: 0.8125rem;
  }

  .wx-visitor-icon {
    font-size: 1rem;
  }

  /* 响应式 */
  @media (max-width: 480px) {
    .wx-feed {
      gap: 1.25rem;
      padding: 0.75rem 0 1.5rem;
    }

    .wx-feed-item + .wx-feed-item::before {
      top: -0.625rem;
      left: 0.75rem;
      right: 0.75rem;
    }
  }

  @media (max-width: 768px) {
    :has(> .page-header-toolbar-slot) {
      flex-direction: column;
    }
    .page-header-toolbar-slot {
      width: 100%;
    }
  }
</style>
