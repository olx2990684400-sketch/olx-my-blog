---
import WriteEditor from "@/components/edit/WriteEditor.svelte";
import { siteConfig } from "@/config";

const navbarTitle = siteConfig.navbar.title || siteConfig.title;
const themeHue = siteConfig.themeColor?.hue || 165;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>写文章 - {siteConfig.title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
  <style is:inline>
    :root {
      --theme-hue: {themeHue};
      --bg-color: #fafafa;
      --bg-secondary: #f3f4f6;
      --card-bg: #ffffff;
      --text-color: #1a1a2e;
      --text-secondary: #6b7280;
      --border: #e5e7eb;
      --radius-large: 20px;
    }
    :root.dark {
      --bg-color: #0f0f1a;
      --bg-secondary: #1a1a2e;
      --card-bg: #141420;
      --text-color: #f0f0f0;
      --text-secondary: #9ca3af;
      --border: #374151;
    }
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    html, body {
      height: 100%;
      width: 100%;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans SC", "Helvetica Neue", Arial, sans-serif;
      background: var(--bg-color);
      color: var(--text-color);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      line-height: 1.6;
      overflow: hidden;
    }
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    ::-webkit-scrollbar-track {
      background: transparent;
    }
    ::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 3px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--text-secondary);
    }
    .page-loading {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      flex-direction: column;
      gap: 16px;
      color: var(--text-secondary);
      font-size: 14px;
    }
    .page-loading .spinner {
      width: 32px;
      height: 32px;
      border: 3px solid var(--border);
      border-top-color: hsl(var(--theme-hue), 70%, 50%);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    #app {
      height: 100vh;
    }
  </style>
  <script is:inline>
    (function() {
      var savedTheme = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var isDark = savedTheme ? savedTheme === 'dark' : prefersDark;
      if (isDark) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <!-- Iconify for editor icons -->
  <script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js" async></script>
</head>
<body>
  <div id="app">
    <div class="page-loading">
      <div class="spinner"></div>
      <p>加载编辑器...</p>
    </div>
    <WriteEditor client:only />
  </div>

  <script is:inline>
    (function() {
      function removeLoading() {
        var loading = document.querySelector('.page-loading');
        if (loading) loading.remove();
      }
      var checkInterval = setInterval(function() {
        var island = document.querySelector('astro-island[client-render-time]');
        if (island) {
          removeLoading();
          clearInterval(checkInterval);
        }
      }, 100);
      setTimeout(function() {
        clearInterval(checkInterval);
        removeLoading();
      }, 3000);
      document.addEventListener('astro:hydration-complete', removeLoading, { once: true });
    })();
  </script>
</body>
</html>
