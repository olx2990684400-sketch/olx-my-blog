---
const pendingText = "菲比正在修建中...";
const pendingImage = "/assets/images/1.webp";
---

<section class="home-pending-layer" aria-labelledby="home-pending-title">
	<div class="onload-animation home-section-title-wrapper">
		<div class="home-section-title-container">
			<span id="home-pending-title" class="home-section-title">维修区</span>
		</div>
	</div>

	<section class="home-pending onload-animation" aria-label="待定区">
		<div class="home-pending__content">
			<span class="home-pending__text">{pendingText}</span>
			<img
				src={pendingImage}
				alt=""
				class="home-pending__image"
				loading="lazy"
				decoding="async"
			/>
		</div>
	</section>
</section>
