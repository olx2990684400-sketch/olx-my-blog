---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import { profileConfig, siteConfig } from "@/config";
import Icon from "@components/common/Icon.astro";

const workHours = siteConfig.workHours ?? {
	start: 9,
	end: 18,
	workDays: [1, 2, 3, 4, 5],
};

const imageFiles = import.meta.glob<ImageMetadata>(
	"../../assets/images/**/*.{png,jpg,jpeg,webp,avif,gif}",
	{
		import: "default",
	},
);

async function optimizeHeroImage(image: ImageMetadata) {
	const optimized = await getImage({
		src: image,
		format: "webp",
		widths: [320],
	});
	return optimized.src;
}

async function resolveHeroImage(src?: string) {
	if (!src) return "";
	if (
		src.startsWith("/") ||
		src.startsWith("http://") ||
		src.startsWith("https://") ||
		src.startsWith("data:")
	) {
		return src;
	}

	const normalizedPath = `../../${src}`.replace(/\\/g, "/");
	const loadImage = imageFiles[normalizedPath];
	if (!loadImage) {
		return `/${src}`;
	}

	const image = await loadImage();
	return optimizeHeroImage(image);
}

const workAvatarEntries = Object.entries(imageFiles)
	.filter(([filePath]) => filePath.includes("/avatar_sb/"))
	.sort(([a], [b]) => a.localeCompare(b));

const workAvatarUrls = await Promise.all(
	workAvatarEntries.map(async ([, loadImage]) =>
		optimizeHeroImage(await loadImage()),
	),
);

const avatarUrl =
	workAvatarUrls[0] ?? (await resolveHeroImage(profileConfig.avatar));
const avatarOffUrl = profileConfig.avatarOffWork
	? await resolveHeroImage(profileConfig.avatarOffWork)
	: avatarUrl;

const heroBioText = Array.isArray(profileConfig.bio)
	? profileConfig.bio[0] || ""
	: profileConfig.bio || "";
---

<section class="home-hero home-hero--motion-pending" id="home-hero"
	data-avatar={avatarUrl}
	data-avatar-pool={JSON.stringify(workAvatarUrls)}
	data-avatar-off={avatarOffUrl}
	data-work-hours={JSON.stringify(workHours)}
>
	<!-- 背景层 -->
	<img class="home-hero__video" src="/assets/images/olx-anime/hero-bright.webp" alt="" />
	<div class="home-hero__ambient" aria-hidden="true">
		<span class="home-hero__ambient-line home-hero__ambient-line--one"></span>
		<span class="home-hero__ambient-line home-hero__ambient-line--two"></span>
		<span class="home-hero__ambient-dot home-hero__ambient-dot--one"></span>
		<span class="home-hero__ambient-dot home-hero__ambient-dot--two"></span>
	</div>

	<!-- 全屏内容容器 -->
	<div class="home-hero__canvas-container" id="main-canvas">
		<!-- 装饰角标 -->
		<div class="home-hero__bracket home-hero__bracket--tl"></div>
		<div class="home-hero__bracket home-hero__bracket--br"></div>
		<div class="home-hero__bottom-line" aria-hidden="true"></div>
		<div class="home-hero__left-line" aria-hidden="true"></div>

		<!-- 左侧面板 -->
		<section class="home-hero__left-panel">
			<div class="home-hero__profile">
				<div class="home-hero__identity-row">
					<!-- 名字 + 职业 组合 -->
					<div class="home-hero__name-group">
						{profileConfig.occupation && (
							<p class="home-hero__occupation">{profileConfig.occupation}</p>
						)}
						{profileConfig.displayName && (
							<h1 class="home-hero__name">{profileConfig.displayName}</h1>
						)}
						<div class="home-hero__name-badge">{profileConfig.nameBadge || ""}</div>
					</div>

					<!-- 头像 + 状态 -->
					<div class="home-hero__avatar-group">
						<div class="home-hero__avatar-wrapper">
							<img
								src={avatarUrl}
								alt="avatar"
								class="home-hero__avatar"
								id="hero-avatar"
								loading="eager"
							/>
						</div>
						<div class="home-hero__status-badge" id="work-status">
							<span class="home-hero__status-dot"></span>
							<span class="home-hero__status-text">上班中</span>
						</div>
					</div>
				</div>

				{heroBioText && (
					<div class="home-hero__motto-wrapper">
						<p class="home-hero__motto-text">{heroBioText}</p>
					</div>
				)}

				<div class="home-hero__signal-panel" data-hero-magnetic>
					<div class="home-hero__signal-topline">
						<span>FIELD NOTES / 2026</span>
						<span>AI · LIFE · EMOTION</span>
					</div>
					<p class="home-hero__signal-copy">把技术的锋利、AI 的新鲜感和生活里的小情绪，写成一张持续更新的个人地图。</p>
					<div class="home-hero__contact-grid" aria-label="联系方式">
						<button class="home-hero__contact-chip home-hero__contact-chip--wechat" type="button" aria-label="微信号 A-XING" title="微信号 A-XING">
							<Icon name="fa7-brands:weixin" is:inline />
							<span class="home-hero__contact-popover" aria-hidden="true">
								<img src="/assets/images/olx-anime/contact-wechat.jpg" alt="" loading="lazy" />
							</span>
						</button>
						<button class="home-hero__contact-chip home-hero__contact-chip--music" type="button" aria-label="网易云 OLX Field Notes" title="网易云 OLX Field Notes">
							<Icon name="material-symbols:music-note-rounded" is:inline />
							<span class="home-hero__contact-popover" aria-hidden="true">
								<img src="/assets/images/olx-anime/contact-netease.jpg" alt="" loading="lazy" />
							</span>
						</button>
						<button class="home-hero__contact-chip home-hero__contact-chip--official" type="button" aria-label="公众号 A-XING" title="公众号 A-XING">
							<Icon name="material-symbols:mark-chat-unread-rounded" is:inline />
							<span class="home-hero__contact-popover" aria-hidden="true">
								<img src="/assets/images/olx-anime/contact-official.jpg" alt="" loading="lazy" />
							</span>
						</button>
					</div>
					<div class="home-hero__signal-actions">
						<a href="/list/" class="home-hero__signal-link" data-hero-magnetic>开始阅读</a>
						<a href="/archive/" class="home-hero__signal-link home-hero__signal-link--ghost" data-hero-magnetic>查看归档</a>
					</div>
				</div>
			</div>
		</section>

		<!-- 中央区 -->
		<section class="home-hero__center-panel">
			<div class="home-hero__art-window"></div>
			<!-- 悬浮人物 -->
			<div class="home-hero__character-root" id="character-layer">
				<div class="home-hero__character-reveal">
					<div class="home-hero__character-motion">
						<img
							src="/assets/images/olx-anime/cola-girl-cutout.png"
							alt="抱着可乐的动漫女生角色"
							class="home-hero__character-img"
							loading="eager"
						/>
					</div>
				</div>
			</div>
			<div class="home-hero__speech" aria-label="Character message">
				<p class="home-hero__speech-text">
					<span class="home-hero__speech-type">今天喝可乐吗？</span>
				</p>
				<p class="home-hero__speech-en">
					<span class="home-hero__speech-type">If you feel tired, have a cold cola and keep going.</span>
				</p>
				<img
					src="/assets/images/home/home2-1.webp"
					alt=""
					class="home-hero__speech-accent"
					loading="eager"
					aria-hidden="true"
				/>
			</div>
		</section>

		<!-- 右侧面板 -->
		<aside class="home-hero__right-panel">
			<div class="home-hero__pill">BLOG</div>
			<div class="home-hero__vertical-wrap">
				<span class="home-hero__v-title">博客</span>
				<span class="home-hero__v-sub">{profileConfig.name || ""}</span>
				<span class="home-hero__diamond">✦</span>
				<span class="home-hero__v-sub">CREATIVE</span>
			</div>
			<div class="home-hero__panel-footer">
				<div class="home-hero__footer-line"></div>
				<p class="home-hero__micro-text">システム起動完了</p>
			</div>
			<div class="home-hero__scroll-meter" aria-hidden="true">
				<span class="home-hero__scroll-meter-fill"></span>
			</div>
		</aside>
	</div>
</section>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { VFX } from "@vfx-js/core";
	import { waitForPageLoaderHidden } from "@/utils/page-loader-controller.js";
	import { HatchEffect } from "@/utils/hatch-effect.ts";

	gsap.registerPlugin(ScrollTrigger);

	let workStatusTimer: number | null = null;
	let heroOpeningTimeline: ReturnType<typeof gsap.timeline> | null = null;
	let vfxInstance: VFX | null = null;
	let heroHatchEffect: HatchEffect | null = null;

	function prefersReducedMotion() {
		return window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	}

	function isMobile() {
		return window.matchMedia("(max-width: 768px)").matches;
	}

	function killHomeMotion() {
		if (heroOpeningTimeline) {
			heroOpeningTimeline.kill();
			heroOpeningTimeline = null;
		}
		ScrollTrigger.getAll().forEach((trigger) => {
			const id = String(trigger.vars.id || "");
			if (id.startsWith("home-motion-")) trigger.kill();
		});
	}

	function initHeroOpening() {
		const hero = document.getElementById("home-hero");
		if (!hero) return Promise.resolve();
		if (prefersReducedMotion() || isMobile()) {
			hero.classList.remove("home-hero--motion-pending");
			hero.classList.add("home-hero--motion-ready");
			return Promise.resolve();
		}

		const occupation = hero.querySelector(".home-hero__occupation");
		const name = hero.querySelector(".home-hero__name");
		const badge = hero.querySelector(".home-hero__name-badge");
		const avatar = hero.querySelector(".home-hero__avatar-group");
		const motto = hero.querySelector(".home-hero__motto-text");
		const artWindow = hero.querySelector(".home-hero__art-window");
		const characterMotion = hero.querySelector(".home-hero__character-motion");
		const speech = hero.querySelector(".home-hero__speech");
		const speechLines = hero.querySelectorAll(".home-hero__speech-type");
		const signalPanel = hero.querySelector(".home-hero__signal-panel");
		const signalItems = hero.querySelectorAll(".home-hero__signal-topline span, .home-hero__signal-copy, .home-hero__contact-chip, .home-hero__signal-link");
		const rightPanel = hero.querySelector(".home-hero__right-panel");
		const scrollMeter = hero.querySelector(".home-hero__scroll-meter");
		const brackets = hero.querySelectorAll(".home-hero__bracket");
		const bottomLine = hero.querySelector(".home-hero__bottom-line");
		const leftLine = hero.querySelector(".home-hero__left-line");

		hero.classList.add("home-hero--motion-ready");

		let resolveHeroTitleReady: () => void;
		const heroTitleReady = new Promise<void>((resolve) => {
			resolveHeroTitleReady = resolve;
		});

		heroOpeningTimeline = gsap.timeline({
			defaults: { ease: "power4.out" },
			onInterrupt: () => resolveHeroTitleReady(),
		});

		heroOpeningTimeline
			.fromTo(brackets, {
				autoAlpha: 0,
				scale: 0.5,
			}, {
				autoAlpha: 1,
				scale: 1,
				duration: 0.8,
				stagger: 0.1,
				ease: "expo.out",
			}, 0.18)
			.fromTo(bottomLine, {
				autoAlpha: 0,
				scaleX: 0,
				transformOrigin: "0% 50%",
			}, {
				autoAlpha: 1,
				scaleX: 1,
				duration: 1.2,
				ease: "expo.out",
			}, 0.34)
			.fromTo(leftLine, {
				autoAlpha: 0,
				scaleY: 0,
				transformOrigin: "50% 100%",
			}, {
				autoAlpha: 1,
				scaleY: 1,
				duration: 1.2,
				ease: "expo.out",
			}, 0.34)
			.fromTo(occupation, {
				autoAlpha: 0,
				y: 48,
				clipPath: "inset(0 0 100% 0)",
			}, {
				autoAlpha: 1,
				y: 0,
				clipPath: "inset(0 0 0% 0)",
				duration: 0.92,
				ease: "expo.out",
			}, 0.82)
			.fromTo(name, {
				autoAlpha: 0,
				x: -78,
				scaleX: 0.78,
				clipPath: "inset(0 100% 0 0)",
				transformOrigin: "0% 50%",
			}, {
				autoAlpha: 1,
				x: 0,
				scaleX: 1,
				clipPath: "inset(0 0% 0 0)",
				duration: 1.18,
				ease: "expo.out",
				onComplete: () => resolveHeroTitleReady(),
			}, 0.98)
			.fromTo(badge, {
				autoAlpha: 0,
				x: -42,
				y: 14,
				scaleX: 0.7,
				transformOrigin: "0% 50%",
			}, {
				autoAlpha: 1,
				x: 0,
				y: 0,
				scaleX: 1,
				duration: 0.78,
				ease: "expo.out",
			}, 1.34)
			.fromTo(avatar, {
				autoAlpha: 0,
				x: 54,
				y: 12,
				scale: 0.82,
				clipPath: "circle(0% at 50% 50%)",
			}, {
				autoAlpha: 1,
				x: 0,
				y: 0,
				scale: 1,
				clipPath: "circle(76% at 50% 50%)",
				duration: 1.05,
				ease: "expo.out",
				clearProps: "clipPath",
			}, 1.45)
			.fromTo(artWindow, {
				autoAlpha: 0,
				x: "7vw",
				clipPath: "inset(0 0 0 100%)",
			}, {
				autoAlpha: 1,
				x: "1vw",
				clipPath: "inset(0 0 0 0%)",
				duration: 1.25,
				ease: "expo.out",
				clearProps: "clipPath",
			}, 1.15)
			.fromTo(characterMotion, {
				autoAlpha: 0,
				y: 58,
				rotationX: 68,
				scaleX: 1.03,
				scaleY: 0.72,
				transformPerspective: 900,
				filter: "blur(10px) saturate(1.1)",
				transformOrigin: "50% 100%",
			}, {
				autoAlpha: 1,
				y: 0,
				rotationX: 0,
				scaleX: 1,
				scaleY: 1,
				filter: "blur(0px) saturate(1)",
				duration: 1.56,
				ease: "expo.out",
				clearProps: "transform,filter,visibility",
			}, 1.42)
			.fromTo(rightPanel, {
				autoAlpha: 0,
				x: 60,
			}, {
				autoAlpha: 1,
				x: 0,
				duration: 0.95,
				ease: "power3.out",
			}, 1.66)
			.fromTo(motto, {
				autoAlpha: 0,
				y: 68,
				filter: "blur(14px)",
				clipPath: "inset(0 0 100% 0)",
			}, {
				autoAlpha: 1,
				y: 0,
				filter: "blur(0px)",
				clipPath: "inset(0 0 0% 0)",
				duration: 1.15,
				ease: "expo.out",
			}, 1.72)
			.fromTo(speech, {
				autoAlpha: 0,
				y: 34,
				scale: 0.92,
				filter: "blur(10px)",
				transformOrigin: "50% 100%",
			}, {
				autoAlpha: 1,
				y: 0,
				scale: 1,
				filter: "blur(0px)",
				duration: 0.92,
				ease: "expo.out",
				clearProps: "filter",
			}, 2.62)
			.fromTo(speechLines, {
				clipPath: "inset(0 100% 0 0)",
			}, {
				clipPath: "inset(0 0% 0 0)",
				duration: 1.05,
				ease: "steps(18)",
			}, 3.08)
			.fromTo(signalPanel, {
				autoAlpha: 0,
				y: 32,
				rotateX: 10,
				filter: "blur(12px)",
				transformOrigin: "50% 100%",
			}, {
				autoAlpha: 1,
				y: 0,
				rotateX: 0,
				filter: "blur(0px)",
				duration: 0.95,
				ease: "expo.out",
				clearProps: "filter",
			}, 2.02)
			.fromTo(signalItems, {
				autoAlpha: 0,
				y: 18,
			}, {
				autoAlpha: 1,
				y: 0,
				duration: 0.62,
				stagger: 0.055,
				ease: "power3.out",
			}, 2.26)
			.fromTo(scrollMeter, {
				autoAlpha: 0,
				scaleY: 0,
				transformOrigin: "50% 100%",
			}, {
				autoAlpha: 1,
				scaleY: 1,
				duration: 0.72,
				ease: "expo.out",
			}, 2.1);

		hero.classList.remove("home-hero--motion-pending");
		return heroTitleReady;
	}

	function initHomeScrollMotion() {
		if (prefersReducedMotion() || isMobile()) {
			document.querySelector(".home-page--motion-pending")?.classList.remove("home-page--motion-pending");
			return;
		}

		const sections = Array.from(document.querySelectorAll<HTMLElement>(
			".home-page > :not(#home-hero), .home-pending-layer",
		)).filter((section, index, list) => list.indexOf(section) === index);

		sections.forEach((section, index) => {
			const title = section.querySelector(".home-section-title, [data-motion-title]");
			const cards = section.querySelectorAll(".card-base, .post-card-wrapper, .home-pending, .stats-container, [data-motion-card]");
			const images = section.querySelectorAll(
			"img[data-home-motion-image]:not([data-shutter-image]):not([data-shutter-final-image]), [data-home-motion-image]:not([data-shutter-image]):not([data-shutter-final-image])",
		);
			if (!title && cards.length === 0 && images.length === 0) return;

			const tl = gsap.timeline({
				scrollTrigger: {
					id: `home-motion-section-${index}`,
					trigger: section,
					start: "top 78%",
					once: true,
				},
				defaults: { ease: "power4.out" },
			});

			if (title) {
				tl.fromTo(title, {
					autoAlpha: 0,
					y: 110,
					scale: 0.82,
					clipPath: "inset(0 0 100% 0)",
				}, {
					autoAlpha: 1,
					y: 0,
					scale: 1,
					clipPath: "inset(0 0 0% 0)",
					duration: 1.05,
					ease: "expo.out",
				});
			}

			if (cards.length > 0) {
				tl.fromTo(cards, {
					autoAlpha: 0,
					y: 86,
					rotateX: 12,
					filter: "blur(12px)",
					transformOrigin: "50% 100%",
				}, {
					autoAlpha: 1,
					y: 0,
					rotateX: 0,
					filter: "blur(0px)",
					duration: 1.05,
					stagger: 0.12,
					ease: "expo.out",
				}, title ? "-=0.38" : 0);
			}

			if (images.length > 0) {
				tl.fromTo(images, {
					clipPath: "inset(0 0 100% 0)",
					scale: 1.1,
				}, {
					clipPath: "inset(0 0 0% 0)",
					scale: 1,
					duration: 1.18,
					stagger: 0.1,
					ease: "expo.out",
				}, "-=0.74");

				images.forEach((image, imageIndex) => {
					gsap.to(image, {
						yPercent: -5,
						ease: "none",
						scrollTrigger: {
							id: `home-motion-image-${index}-${imageIndex}`,
							trigger: image,
							start: "top bottom",
							end: "bottom top",
							scrub: 0.9,
						},
					});
				});
			}
		});

		document.querySelector(".home-page--motion-pending")?.classList.remove("home-page--motion-pending");
	}

	// ============================================
	// 鼠标视差 + 人物浮动
	// ============================================
	let rafId: number | null = null;
	let mouseX = 0;
	let mouseY = 0;
	let charX = 0;
	let charY = 0;
	let mouseMoveHandler: ((e: MouseEvent) => void) | null = null;
	let parallaxRunning = false;

	function initParallax() {
		if (isMobile()) return;
		const charLayer = document.getElementById("character-layer");
		if (!charLayer) return;

		mouseMoveHandler = (e: MouseEvent) => {
			mouseX = (e.clientX - window.innerWidth / 2) / (window.innerWidth / 2);
			mouseY = (e.clientY - window.innerHeight / 2) / (window.innerHeight / 2);
			// 鼠标移动时重新启动 rAF 循环
			if (!parallaxRunning) {
				parallaxRunning = true;
				rafId = requestAnimationFrame(update);
			}
		};

		document.addEventListener("mousemove", mouseMoveHandler);

		function update() {
			const targetX = mouseX * 18;
			const targetY = mouseY * 12;

			charX += (targetX - charX) * 0.08;
			charY += (targetY - charY) * 0.08;

			if (charLayer) {
				charLayer.style.transform = `translate(${charX}px, ${charY}px)`;
			}

			// 收敛检测：差值足够小时暂停循环，鼠标移动时重新启动
			if (Math.abs(targetX - charX) < 0.01 && Math.abs(targetY - charY) < 0.01) {
				parallaxRunning = false;
				rafId = null;
				return;
			}

			rafId = requestAnimationFrame(update);
		}

		parallaxRunning = true;
		rafId = requestAnimationFrame(update);
	}

	function destroyParallax() {
		if (mouseMoveHandler) {
			document.removeEventListener("mousemove", mouseMoveHandler);
			mouseMoveHandler = null;
		}
		if (rafId) {
			cancelAnimationFrame(rafId);
			rafId = null;
		}
	}

	// ============================================
	// 精致交互：磁吸按钮 + 首屏滚动进度
	// ============================================
	let magneticCleanup: (() => void) | null = null;

	function initHeroInteractions() {
		if (prefersReducedMotion() || isMobile()) return;
		const hero = document.getElementById("home-hero");
		if (!hero) return;
		const magneticItems = Array.from(hero.querySelectorAll<HTMLElement>(".home-hero__signal-link"));
		const listeners: Array<() => void> = [];

		magneticItems.forEach((item) => {
			const xTo = gsap.quickTo(item, "x", { duration: 0.34, ease: "power3.out" });
			const yTo = gsap.quickTo(item, "y", { duration: 0.34, ease: "power3.out" });
			const onMove = (event: MouseEvent) => {
				const rect = item.getBoundingClientRect();
				const x = ((event.clientX - rect.left) / rect.width - 0.5) * 10;
				const y = ((event.clientY - rect.top) / rect.height - 0.5) * 8;
				xTo(x);
				yTo(y);
			};
			const onLeave = () => {
				xTo(0);
				yTo(0);
			};
			item.addEventListener("mousemove", onMove);
			item.addEventListener("mouseleave", onLeave);
			item.addEventListener("blur", onLeave);
			listeners.push(() => {
				item.removeEventListener("mousemove", onMove);
				item.removeEventListener("mouseleave", onLeave);
				item.removeEventListener("blur", onLeave);
			});
		});

		const meterFill = hero.querySelector(".home-hero__scroll-meter-fill");
		if (meterFill) {
			ScrollTrigger.create({
				id: "home-motion-hero-meter",
				trigger: hero,
				start: "top top",
				end: "bottom top",
				onUpdate: (self) => {
					gsap.set(meterFill, { scaleY: Math.max(0.08, self.progress), transformOrigin: "50% 100%" });
				},
			});
		}

		magneticCleanup = () => {
			listeners.forEach((remove) => remove());
			magneticCleanup = null;
		};
	}

	function destroyHeroInteractions() {
		if (magneticCleanup) magneticCleanup();
	}

	// ============================================
	// 上下班头像与状态牌
	// ============================================
	function initWorkStatus() {
		if (workStatusTimer) {
			window.clearInterval(workStatusTimer);
			workStatusTimer = null;
		}

		const hero = document.getElementById("home-hero");
		const avatar = document.getElementById("hero-avatar") as HTMLImageElement | null;
		const badge = document.getElementById("work-status");
		const statusText = badge?.querySelector(".home-hero__status-text");
		if (!hero || !avatar || !badge || !statusText) return;
		const heroEl = hero;
		const avatarEl = avatar;
		const badgeEl = badge;
		const statusTextEl = statusText;
		let selectedWorkAvatar = "";

		function getWorkAvatarUrl() {
			if (selectedWorkAvatar) return selectedWorkAvatar;
			try {
				const pool = JSON.parse(heroEl.dataset.avatarPool || "[]");
				if (Array.isArray(pool) && pool.length > 0) {
					selectedWorkAvatar = pool[Math.floor(Math.random() * pool.length)];
					return selectedWorkAvatar;
				}
			} catch {
				// Keep the configured avatar fallback when the pool data is malformed.
			}
			selectedWorkAvatar = heroEl.dataset.avatar || "";
			return selectedWorkAvatar;
		}

		const workHoursData = heroEl.dataset.workHours;
		let workHours = { start: 9, end: 18, workDays: [1, 2, 3, 4, 5] };
		if (workHoursData) {
			try {
				workHours = JSON.parse(workHoursData);
			} catch {
				// Keep defaults when config data is malformed.
			}
		}

		function updateStatus() {
			const now = new Date();
			const hour = now.getHours() + now.getMinutes() / 60;
			const day = now.getDay();
			const isWorkday = workHours.workDays.includes(day);
			const isWorking = isWorkday && hour >= workHours.start && hour < workHours.end;
			const nextAvatar = isWorking ? getWorkAvatarUrl() : heroEl.dataset.avatarOff;

			if (nextAvatar && avatarEl.getAttribute("src") !== nextAvatar) {
				avatarEl.setAttribute("src", nextAvatar);
			}
			statusTextEl.textContent = isWorking ? "上班中" : "下班";
			badgeEl.classList.toggle("is-off-work", !isWorking);
		}

		updateStatus();
		workStatusTimer = window.setInterval(updateStatus, 60_000);
	}

	function destroyWorkStatus() {
		if (workStatusTimer) {
			window.clearInterval(workStatusTimer);
			workStatusTimer = null;
		}
	}

	// ============================================
	// 标题 Hatching Shader 效果
	// ============================================
	async function initHeroHatch(heroTitleReady: Promise<void>, token: number) {
		const nameEl = document.querySelector<HTMLElement>(".home-hero__name");
		if (!nameEl) return;
		if (prefersReducedMotion() || isMobile()) return;

		await heroTitleReady;

		// 再次检查元素是否仍在 DOM（Swup 可能已切走页面）
		if (token !== initToken || !document.contains(nameEl)) return;

		destroyHeroHatch();

		const vfx = VFX.init({ pixelRatio: Math.min(window.devicePixelRatio, 1.5) });
		if (!vfx) return;
		vfxInstance = vfx;

		heroHatchEffect = new HatchEffect({
			color: "#ffffff",
			angle: 45,
			spacing: 2.5,
			lineWidth: 2,
			angleJitter: 0.5,
			offsetJitter: 2,
			spacingJitter: 0.5,
			seed: 0,
			speed: 8,
			roundCap: true,
			soft: 0,
			originalColor: false,
			bypass: false,
		});

		try {
			await vfx.addHTML(nameEl, { effect: heroHatchEffect });
		} catch { /* ignore */ }
	}

	function destroyHeroHatch() {
		if (vfxInstance) {
			const nameEl = document.querySelector<HTMLElement>(".home-hero__name");
			if (nameEl) {
				try { vfxInstance.remove(nameEl); } catch { /* ignore */ }
			}
		}
		if (heroHatchEffect) {
			heroHatchEffect.dispose();
			heroHatchEffect = null;
		}
		if (vfxInstance) {
			vfxInstance.destroy();
			vfxInstance = null;
		}
	}

	// ============================================
	// 初始化与清理（Swup 兼容）
	// ============================================
	let initToken = 0;

	function init() {
		cleanup();
		const token = initToken;
		const heroOpeningReady = initHeroOpening();
		initParallax();
		initWorkStatus();
		initHeroInteractions();
		void initHeroHatch(heroOpeningReady, token);

		// 推迟 ScrollTrigger 初始化，避免阻塞 Hero 入场动画的首次渲染
		requestAnimationFrame(() => {
			initHomeScrollMotion();
		});
	}

	function cleanup() {
		killHomeMotion();
		destroyParallax();
		destroyWorkStatus();
		destroyHeroHatch();
		destroyHeroInteractions();
	}

	async function scheduleHomeInit() {
		const token = ++initToken;
		cleanup();
		if (!document.getElementById("home-hero")) return;

		await waitForPageLoaderHidden();
		if (token !== initToken || !document.getElementById("home-hero")) return;

		init();
	}

	// 首次初始化：等页面加载遮罩完全撤掉后再播放首页入场
	void scheduleHomeInit();

	// Swup 兼容：使用 astro:page-load（每次导航完成触发）
	document.addEventListener("astro:page-load", () => {
		const hero = document.getElementById("home-hero");
		if (hero) {
			void scheduleHomeInit();
		} else {
			initToken += 1;
			cleanup();
		}
	});
</script>
