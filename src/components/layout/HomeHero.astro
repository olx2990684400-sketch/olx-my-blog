---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import { profileConfig, siteConfig } from "@/config";

const workHours = siteConfig.workHours ?? {
	start: 9,
	end: 18,
	workDays: [1, 2, 3, 4, 5],
};

const imageFiles = import.meta.glob<ImageMetadata>(
	"../../assets/images/**/*.{png,jpg,jpeg,webp,avif,gif}",
	{
		import: "default",
	},
);

async function optimizeHeroImage(image: ImageMetadata) {
	const optimized = await getImage({
		src: image,
		format: "webp",
		widths: [320],
	});
	return optimized.src;
}

async function resolveHeroImage(src?: string) {
	if (!src) return "";
	if (
		src.startsWith("/") ||
		src.startsWith("http://") ||
		src.startsWith("https://") ||
		src.startsWith("data:")
	) {
		return src;
	}

	const normalizedPath = `../../${src}`.replace(/\\/g, "/");
	const loadImage = imageFiles[normalizedPath];
	if (!loadImage) {
		return `/${src}`;
	}

	const image = await loadImage();
	return optimizeHeroImage(image);
}

const workAvatarEntries = Object.entries(imageFiles)
	.filter(([filePath]) => filePath.includes("/avatar_sb/"))
	.sort(([a], [b]) => a.localeCompare(b));

const workAvatarUrls = await Promise.all(
	workAvatarEntries.map(async ([, loadImage]) =>
		optimizeHeroImage(await loadImage()),
	),
);

const avatarUrl =
	workAvatarUrls[0] ?? (await resolveHeroImage(profileConfig.avatar));
const avatarOffUrl = profileConfig.avatarOffWork
	? await resolveHeroImage(profileConfig.avatarOffWork)
	: avatarUrl;

const heroBioText = Array.isArray(profileConfig.bio)
	? profileConfig.bio[0] || ""
	: profileConfig.bio || "";
---

<section class="home-hero home-hero--motion-pending" id="home-hero"
	data-avatar={avatarUrl}
	data-avatar-pool={JSON.stringify(workAvatarUrls)}
	data-avatar-off={avatarOffUrl}
	data-work-hours={JSON.stringify(workHours)}
>
	<!-- 背景层 -->
	<video class="home-hero__video" autoplay muted loop playsinline poster="/assets/images/home/home1.webp">
		<source src="/assets/images/home/home1.mp4" type="video/mp4">
	</video>
	<div class="home-hero__bg"></div>
	<div class="home-hero__vignette"></div>
	<div class="home-hero__dot-overlay"></div>

	<!-- 花瓣 Canvas -->
	<canvas class="home-hero__petals" id="petals-canvas"></canvas>

	<!-- 全屏内容容器 -->
	<div class="home-hero__canvas-container" id="main-canvas">
		<!-- 装饰角标 -->
		<div class="home-hero__bracket home-hero__bracket--tl"></div>
		<div class="home-hero__bracket home-hero__bracket--br"></div>
		<div class="home-hero__bottom-line" aria-hidden="true"></div>

		<!-- 左侧面板 -->
		<section class="home-hero__left-panel">
			<div class="home-hero__profile">
				<div class="home-hero__identity-row">
					<!-- 名字 + 职业 组合 -->
					<div class="home-hero__name-group">
						{profileConfig.occupation && (
							<p class="home-hero__occupation">{profileConfig.occupation}</p>
						)}
						{profileConfig.displayName && (
							<h1 class="home-hero__name">{profileConfig.displayName}</h1>
						)}
						<div class="home-hero__name-badge">784774835</div>
					</div>

					<!-- 头像 + 状态 -->
					<div class="home-hero__avatar-group">
						<div class="home-hero__avatar-wrapper">
							<img
								src={avatarUrl}
								alt="avatar"
								class="home-hero__avatar"
								id="hero-avatar"
								loading="eager"
							/>
						</div>
						<div class="home-hero__status-badge" id="work-status">
							<span class="home-hero__status-dot"></span>
							<span class="home-hero__status-text">上班中</span>
						</div>
					</div>
				</div>

				{heroBioText && (
					<div class="home-hero__motto-wrapper">
						<p class="home-hero__motto-text">{heroBioText}</p>
					</div>
				)}
			</div>
		</section>

		<!-- 中央区 -->
		<section class="home-hero__center-panel">
			<div class="home-hero__art-window"></div>
			<!-- 悬浮人物 -->
			<div class="home-hero__character-root" id="character-layer">
				<div class="home-hero__character-reveal">
					<div class="home-hero__character-motion">
						<img
							src="/assets/images/home/home2.webp"
							alt="character"
							class="home-hero__character-img"
							loading="eager"
						/>
					</div>
				</div>
			</div>
			<div class="home-hero__speech" aria-label="Character message">
				<p class="home-hero__speech-text">
					<span class="home-hero__speech-type">菲比啾比？</span>
				</p>
				<p class="home-hero__speech-en">
					<span class="home-hero__speech-type">If you feel tired, you might as well have a glass of juice?</span>
				</p>
				<img
					src="/assets/images/home/home2-1.webp"
					alt=""
					class="home-hero__speech-accent"
					loading="eager"
					aria-hidden="true"
				/>
			</div>
		</section>

		<!-- 右侧面板 -->
		<aside class="home-hero__right-panel">
			<div class="home-hero__pill">BLOG</div>
			<div class="home-hero__vertical-wrap">
				<span class="home-hero__v-title">{siteConfig.title || "Blog"}</span>
				<span class="home-hero__v-sub">{profileConfig.name || ""}</span>
				<span class="home-hero__diamond">✦</span>
				<span class="home-hero__v-sub">CREATIVE</span>
			</div>
			<div class="home-hero__panel-footer">
				<div class="home-hero__footer-line"></div>
				<p class="home-hero__micro-text">システム起動完了</p>
			</div>
		</aside>
	</div>
</section>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { waitForPageLoaderHidden } from "@/utils/page-loader-controller.js";

	gsap.registerPlugin(ScrollTrigger);

	let workStatusTimer: number | null = null;
	let heroOpeningTimeline: ReturnType<typeof gsap.timeline> | null = null;

	function prefersReducedMotion() {
		return window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	}

	function killHomeMotion() {
		if (heroOpeningTimeline) {
			heroOpeningTimeline.kill();
			heroOpeningTimeline = null;
		}
		ScrollTrigger.getAll().forEach((trigger) => {
			const id = String(trigger.vars.id || "");
			if (id.startsWith("home-motion-")) trigger.kill();
		});
	}

	function initHeroOpening() {
		const hero = document.getElementById("home-hero");
		if (!hero) return;
		if (prefersReducedMotion()) {
			hero.classList.remove("home-hero--motion-pending");
			hero.classList.add("home-hero--motion-ready");
			return;
		}

		const occupation = hero.querySelector(".home-hero__occupation");
		const name = hero.querySelector(".home-hero__name");
		const badge = hero.querySelector(".home-hero__name-badge");
		const avatar = hero.querySelector(".home-hero__avatar-group");
		const motto = hero.querySelector(".home-hero__motto-text");
		const artWindow = hero.querySelector(".home-hero__art-window");
		const characterMotion = hero.querySelector(".home-hero__character-motion");
		const speech = hero.querySelector(".home-hero__speech");
		const speechLines = hero.querySelectorAll(".home-hero__speech-type");
		const rightPanel = hero.querySelector(".home-hero__right-panel");
		const brackets = hero.querySelectorAll(".home-hero__bracket");
		const bottomLine = hero.querySelector(".home-hero__bottom-line");
		const bg = hero.querySelector(".home-hero__bg");

		hero.classList.add("home-hero--motion-ready");

		heroOpeningTimeline = gsap.timeline({
			defaults: { ease: "power4.out" },
		});

		heroOpeningTimeline
			.fromTo(bg, {
				autoAlpha: 0.68,
				scale: 1.14,
				filter: "blur(8px)",
			}, {
				autoAlpha: 1,
				scale: 1,
				filter: "blur(0px)",
				duration: 2.05,
				ease: "expo.out",
			})
			.fromTo(brackets, {
				autoAlpha: 0,
				scale: 0.5,
			}, {
				autoAlpha: 1,
				scale: 1,
				duration: 0.8,
				stagger: 0.1,
				ease: "expo.out",
			}, 0.18)
			.fromTo(bottomLine, {
				autoAlpha: 0,
				scaleX: 0,
				transformOrigin: "0% 50%",
			}, {
				autoAlpha: 1,
				scaleX: 1,
				duration: 1.2,
				ease: "expo.out",
			}, 0.34)
			.fromTo(occupation, {
				autoAlpha: 0,
				y: 48,
				clipPath: "inset(0 0 100% 0)",
			}, {
				autoAlpha: 1,
				y: 0,
				clipPath: "inset(0 0 0% 0)",
				duration: 0.92,
				ease: "expo.out",
			}, 0.82)
			.fromTo(name, {
				autoAlpha: 0,
				x: -78,
				scaleX: 0.78,
				clipPath: "inset(0 100% 0 0)",
				transformOrigin: "0% 50%",
			}, {
				autoAlpha: 1,
				x: 0,
				scaleX: 1,
				clipPath: "inset(0 0% 0 0)",
				duration: 1.18,
				ease: "expo.out",
			}, 0.98)
			.fromTo(badge, {
				autoAlpha: 0,
				x: -42,
				y: 14,
				scaleX: 0.7,
				transformOrigin: "0% 50%",
			}, {
				autoAlpha: 1,
				x: 0,
				y: 0,
				scaleX: 1,
				duration: 0.78,
				ease: "expo.out",
			}, 1.34)
			.fromTo(avatar, {
				autoAlpha: 0,
				x: 54,
				y: 12,
				scale: 0.82,
				clipPath: "circle(0% at 50% 50%)",
			}, {
				autoAlpha: 1,
				x: 0,
				y: 0,
				scale: 1,
				clipPath: "circle(76% at 50% 50%)",
				duration: 1.05,
				ease: "expo.out",
				clearProps: "clipPath",
			}, 1.45)
			.fromTo(artWindow, {
				autoAlpha: 0,
				x: "7vw",
				clipPath: "inset(0 0 0 100%)",
			}, {
				autoAlpha: 1,
				x: "1vw",
				clipPath: "inset(0 0 0 0%)",
				duration: 1.25,
				ease: "expo.out",
				clearProps: "clipPath",
			}, 1.15)
			.fromTo(characterMotion, {
				autoAlpha: 0,
				y: 58,
				rotationX: 68,
				scaleX: 1.03,
				scaleY: 0.72,
				transformPerspective: 900,
				filter: "blur(10px) saturate(1.1)",
				transformOrigin: "50% 100%",
			}, {
				autoAlpha: 1,
				y: 0,
				rotationX: 0,
				scaleX: 1,
				scaleY: 1,
				filter: "blur(0px) saturate(1)",
				duration: 1.56,
				ease: "expo.out",
				clearProps: "transform,filter,visibility",
			}, 1.42)
			.fromTo(rightPanel, {
				autoAlpha: 0,
				x: 60,
			}, {
				autoAlpha: 1,
				x: 0,
				duration: 0.95,
				ease: "power3.out",
			}, 1.66)
			.fromTo(motto, {
				autoAlpha: 0,
				y: 68,
				filter: "blur(14px)",
				clipPath: "inset(0 0 100% 0)",
			}, {
				autoAlpha: 1,
				y: 0,
				filter: "blur(0px)",
				clipPath: "inset(0 0 0% 0)",
				duration: 1.15,
				ease: "expo.out",
			}, 1.72)
			.fromTo(speech, {
				autoAlpha: 0,
				xPercent: -50,
				y: 34,
				scale: 0.92,
				filter: "blur(10px)",
				transformOrigin: "50% 100%",
			}, {
				autoAlpha: 1,
				xPercent: -50,
				y: 0,
				scale: 1,
				filter: "blur(0px)",
				duration: 0.92,
				ease: "expo.out",
				clearProps: "filter",
			}, 2.62)
			.fromTo(speechLines, {
				clipPath: "inset(0 100% 0 0)",
			}, {
				clipPath: "inset(0 0% 0 0)",
				duration: 1.05,
				ease: "steps(18)",
			}, 3.08);

		hero.classList.remove("home-hero--motion-pending");
	}

	function initHomeScrollMotion() {
		if (prefersReducedMotion()) {
			document.querySelector(".home-page--motion-pending")?.classList.remove("home-page--motion-pending");
			return;
		}

		const sections = Array.from(document.querySelectorAll<HTMLElement>(
			".home-page > :not(#home-hero), .home-status, .home-pending-layer",
		)).filter((section, index, list) => list.indexOf(section) === index);

		sections.forEach((section, index) => {
			const title = section.querySelector(".home-section-title, [data-motion-title]");
			const cards = section.querySelectorAll(".card-base, .post-card-wrapper, .home-pending, .stats-container, [data-motion-card]");
			const images = section.querySelectorAll("img, [data-motion-image]");
			if (!title && cards.length === 0 && images.length === 0) return;

			const tl = gsap.timeline({
				scrollTrigger: {
					id: `home-motion-section-${index}`,
					trigger: section,
					start: "top 78%",
					once: true,
				},
				defaults: { ease: "power4.out" },
			});

			if (title) {
				tl.fromTo(title, {
					autoAlpha: 0,
					y: 110,
					scale: 0.82,
					clipPath: "inset(0 0 100% 0)",
				}, {
					autoAlpha: 1,
					y: 0,
					scale: 1,
					clipPath: "inset(0 0 0% 0)",
					duration: 1.05,
					ease: "expo.out",
				});
			}

			if (cards.length > 0) {
				tl.fromTo(cards, {
					autoAlpha: 0,
					y: 86,
					rotateX: 12,
					filter: "blur(12px)",
					transformOrigin: "50% 100%",
				}, {
					autoAlpha: 1,
					y: 0,
					rotateX: 0,
					filter: "blur(0px)",
					duration: 1.05,
					stagger: 0.12,
					ease: "expo.out",
				}, title ? "-=0.38" : 0);
			}

			if (images.length > 0) {
				tl.fromTo(images, {
					clipPath: "inset(0 0 100% 0)",
					scale: 1.1,
				}, {
					clipPath: "inset(0 0 0% 0)",
					scale: 1,
					duration: 1.18,
					stagger: 0.1,
					ease: "expo.out",
				}, "-=0.74");

				images.forEach((image, imageIndex) => {
					gsap.to(image, {
						yPercent: -5,
						ease: "none",
						scrollTrigger: {
							id: `home-motion-image-${index}-${imageIndex}`,
							trigger: image,
							start: "top bottom",
							end: "bottom top",
							scrub: 0.9,
						},
					});
				});
			}
		});

		document.querySelector(".home-page--motion-pending")?.classList.remove("home-page--motion-pending");
	}

	// ============================================
	// 鼠标视差 + 人物浮动
	// ============================================
	let rafId: number | null = null;
	let mouseX = 0;
	let mouseY = 0;
	let charX = 0;
	let charY = 0;
	let petalsParamX = 0;
	let mouseMoveHandler: ((e: MouseEvent) => void) | null = null;

	function initParallax() {
		const charLayer = document.getElementById("character-layer");
		if (!charLayer) return;

		mouseMoveHandler = (e: MouseEvent) => {
			mouseX = (e.clientX - window.innerWidth / 2) / (window.innerWidth / 2);
			mouseY = (e.clientY - window.innerHeight / 2) / (window.innerHeight / 2);
		};

		document.addEventListener("mousemove", mouseMoveHandler);

		function update() {
			const targetX = mouseX * 18;
			const targetY = mouseY * 12;

			charX += (targetX - charX) * 0.08;
			charY += (targetY - charY) * 0.08;
			petalsParamX += (-mouseX * 10 - petalsParamX) * 0.05;

			if (charLayer) {
				charLayer.style.transform = `translate(${charX}px, ${charY}px)`;
			}
			rafId = requestAnimationFrame(update);
		}

		rafId = requestAnimationFrame(update);
	}

	function destroyParallax() {
		if (mouseMoveHandler) {
			document.removeEventListener("mousemove", mouseMoveHandler);
			mouseMoveHandler = null;
		}
		if (rafId) {
			cancelAnimationFrame(rafId);
			rafId = null;
		}
	}

	// ============================================
	// 花瓣飘落 Canvas
	// ============================================
	let petalRafId: number | null = null;
	let petalCleanupFn: (() => void) | null = null;

	function initPetals() {
		const canvas = document.getElementById("petals-canvas") as HTMLCanvasElement | null;
		const mainCanvas = document.getElementById("main-canvas");
		if (!canvas || !mainCanvas) return;
		const canvasEl = canvas;
		const mainCanvasEl = mainCanvas;

		const ctx = canvasEl.getContext("2d");
		if (!ctx) return;
		const context = ctx;

		const isMobile = window.innerWidth <= 768;
		const maxPetals = isMobile ? 15 : 30;

		function resize() {
			const rect = mainCanvasEl.getBoundingClientRect();
			canvasEl.width = rect.width;
			canvasEl.height = rect.height;
		}
		resize();

		const ro = new ResizeObserver(resize);
		ro.observe(mainCanvasEl);
		window.addEventListener("resize", resize);

		const colors = [
			"rgba(239, 68, 68, 0.25)",
			"rgba(249, 115, 22, 0.20)",
			"rgba(254, 205, 211, 0.25)",
		];

		class Petal {
			x: number;
			y: number;
			size: number;
			speedY: number;
			speedX: number;
			angle: number;
			spin: number;
			color: string;

			constructor() {
				this.x = Math.random() * canvasEl.width;
				this.y = Math.random() * -canvasEl.height;
				this.size = Math.random() * 5 + 3;
				this.speedY = Math.random() * 0.7 + 0.3;
				this.speedX = Math.random() * 0.4 - 0.2;
				this.angle = Math.random() * 360;
				this.spin = Math.random() * 0.8 - 0.4;
				this.color = colors[Math.floor(Math.random() * colors.length)];
			}

			update() {
				this.y += this.speedY;
				this.x += this.speedX + Math.sin(this.y / 40) * 0.25 + (petalsParamX * 0.02);
				this.angle += this.spin;

				if (this.y > canvasEl.height + 10) {
					this.y = -10;
					this.x = Math.random() * canvasEl.width;
				}
			}

			draw() {
				context.save();
				context.translate(this.x, this.y);
				context.rotate((this.angle * Math.PI) / 180);
				context.fillStyle = this.color;
				context.beginPath();
				context.ellipse(0, 0, this.size, this.size / 1.8, 0, 0, 2 * Math.PI);
				context.fill();
				context.restore();
			}
		}

		const petals: Petal[] = [];
		for (let i = 0; i < maxPetals; i++) {
			petals.push(new Petal());
		}

		function animate() {
			context.clearRect(0, 0, canvasEl.width, canvasEl.height);
			for (const petal of petals) {
				petal.update();
				petal.draw();
			}
			petalRafId = requestAnimationFrame(animate);
		}
		animate();

		petalCleanupFn = () => {
			ro.disconnect();
			window.removeEventListener("resize", resize);
			if (petalRafId) cancelAnimationFrame(petalRafId);
		};
	}

	function destroyPetals() {
		if (petalCleanupFn) {
			petalCleanupFn();
			petalCleanupFn = null;
		}
	}

	// ============================================
	// 上下班头像与状态牌
	// ============================================
	function initWorkStatus() {
		if (workStatusTimer) {
			window.clearInterval(workStatusTimer);
			workStatusTimer = null;
		}

		const hero = document.getElementById("home-hero");
		const avatar = document.getElementById("hero-avatar") as HTMLImageElement | null;
		const badge = document.getElementById("work-status");
		const statusText = badge?.querySelector(".home-hero__status-text");
		if (!hero || !avatar || !badge || !statusText) return;
		const heroEl = hero;
		const avatarEl = avatar;
		const badgeEl = badge;
		const statusTextEl = statusText;
		let selectedWorkAvatar = "";

		function getWorkAvatarUrl() {
			if (selectedWorkAvatar) return selectedWorkAvatar;
			try {
				const pool = JSON.parse(heroEl.dataset.avatarPool || "[]");
				if (Array.isArray(pool) && pool.length > 0) {
					selectedWorkAvatar = pool[Math.floor(Math.random() * pool.length)];
					return selectedWorkAvatar;
				}
			} catch {
				// Keep the configured avatar fallback when the pool data is malformed.
			}
			selectedWorkAvatar = heroEl.dataset.avatar || "";
			return selectedWorkAvatar;
		}

		const workHoursData = heroEl.dataset.workHours;
		let workHours = { start: 9, end: 18, workDays: [1, 2, 3, 4, 5] };
		if (workHoursData) {
			try {
				workHours = JSON.parse(workHoursData);
			} catch {
				// Keep defaults when config data is malformed.
			}
		}

		function updateStatus() {
			const now = new Date();
			const hour = now.getHours() + now.getMinutes() / 60;
			const day = now.getDay();
			const isWorkday = workHours.workDays.includes(day);
			const isWorking = isWorkday && hour >= workHours.start && hour < workHours.end;
			const nextAvatar = isWorking ? getWorkAvatarUrl() : heroEl.dataset.avatarOff;

			if (nextAvatar && avatarEl.getAttribute("src") !== nextAvatar) {
				avatarEl.setAttribute("src", nextAvatar);
			}
			statusTextEl.textContent = isWorking ? "上班中" : "下班";
			badgeEl.classList.toggle("is-off-work", !isWorking);
		}

		updateStatus();
		workStatusTimer = window.setInterval(updateStatus, 60_000);
	}

	function destroyWorkStatus() {
		if (workStatusTimer) {
			window.clearInterval(workStatusTimer);
			workStatusTimer = null;
		}
	}

	// ============================================
	// 初始化与清理（Swup 兼容）
	// ============================================
	let initToken = 0;

	function init() {
		cleanup();
		initHeroOpening();
		initHomeScrollMotion();
		initParallax();
		initPetals();
		initWorkStatus();
	}

	function cleanup() {
		killHomeMotion();
		destroyParallax();
		destroyPetals();
		destroyWorkStatus();
	}

	async function scheduleHomeInit() {
		const token = ++initToken;
		cleanup();
		if (!document.getElementById("home-hero")) return;

		await waitForPageLoaderHidden();
		if (token !== initToken || !document.getElementById("home-hero")) return;

		init();
	}

	// 首次初始化：等页面加载遮罩完全撤掉后再播放首页入场
	void scheduleHomeInit();

	// Swup 兼容：使用 astro:page-load（每次导航完成触发）
	document.addEventListener("astro:page-load", () => {
		const hero = document.getElementById("home-hero");
		if (hero) {
			void scheduleHomeInit();
		} else {
			initToken += 1;
			cleanup();
		}
	});
</script>
