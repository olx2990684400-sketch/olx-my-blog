---
/**
 * 极简门户区：将原侧边栏中的"门户级信息"以纯文本垂直堆叠展示。
 * 每块仅用 [ LABEL ] 小标签 + 细线分隔，无卡片填充。
 *
 * 包含：Profile / Announcement / Stats / Categories / Tags
 * 重组件（Music / Calendar / Live2D / Spine）由右下浮动坞触达，不在此处。
 */
import Icon from "@components/common/Icon.astro";
import ImageWrapper from "@/components/common/ImageWrapper.astro";
import NumberTicker from "@/components/common/NumberTicker.svelte";
import TypewriterText from "@/components/features/TypewriterText.astro";
import { profileConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import {
	getCategoryList,
	getSortedPosts,
	getTagList,
} from "@/utils/content-utils";
import { url } from "@/utils/url-utils";

const posts = await getSortedPosts();
const categories = await getCategoryList();
const tags = await getTagList();

let totalWords = 0;
for (const post of posts) {
	if (post.body) {
		const text = post.body
			.replace(/```[\s\S]*?```/g, "")
			.replace(/`[^`]*`/g, "")
			.replace(/\s+/g, " ")
			.trim();
		const cn = text.match(/[一-龥]/g) || [];
		const en = text.match(/[a-zA-Z]/g) || [];
		totalWords += cn.length + en.length;
	}
}

const siteStartDate = siteConfig.siteStartDate || "2025-01-01";
const latestPost = posts[0];

// 计算运行天数（服务端计算）
const startDate = new Date(siteStartDate);
const today = new Date();
const diffTime = Math.abs(today.getTime() - startDate.getTime());
const runningDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

// 计算活跃天数
let lastUpdateDays = 0;
let isToday = false;
if (latestPost) {
	const lastPost = latestPost.data.published;
	const timeSinceLastPost = Math.abs(today.getTime() - lastPost.getTime());
	lastUpdateDays = Math.floor(timeSinceLastPost / (1000 * 60 * 60 * 24));
	isToday = lastUpdateDays === 0;
}

const stats = [
	{
		icon: "material-symbols:article-outline",
		label: i18n(I18nKey.siteStatsPostCount),
		value: posts.length,
	},
	{
		icon: "material-symbols:folder-outline",
		label: i18n(I18nKey.siteStatsCategoryCount),
		value: categories.length,
	},
	{
		icon: "material-symbols:label-outline",
		label: i18n(I18nKey.siteStatsTagCount),
		value: tags.length,
	},
	{
		icon: "material-symbols:text-ad-outline-rounded",
		label: i18n(I18nKey.siteStatsTotalWords),
		value: totalWords,
		formatted: true,
	},
	{
		icon: "material-symbols:calendar-clock-outline",
		label: i18n(I18nKey.siteStatsRunningDays),
		value: runningDays,
		hideValue: runningDays === 0,
		suffix:
			runningDays === 0
				? i18n(I18nKey.today)
				: i18n(I18nKey.siteStatsDays).replace("{days}", ""),
	},
	{
		icon: "mingcute:heartbeat-line",
		label: i18n(I18nKey.siteStatsLastUpdate),
		value: isToday ? 0 : lastUpdateDays,
		hideValue: isToday,
		suffix: isToday
			? i18n(I18nKey.today)
			: i18n(I18nKey.siteStatsDaysAgo).replace("{days}", ""),
	},
	{
		icon: "material-symbols:eye-tracking-outline",
		label: i18n(I18nKey.siteStatsVisitors),
		value: 0,
		hideValue: true,
		suffix: i18n(I18nKey.siteStatsLoading),
		id: "counter-uv",
	},
	{
		icon: "material-symbols:visibility-outline-rounded",
		label: i18n(I18nKey.siteStatsPageViews),
		value: 0,
		hideValue: true,
		suffix: i18n(I18nKey.siteStatsLoading),
		id: "counter-pv",
	},
];
---

<div class="home-portal">
	{/* PROFILE */}
	<section class="section onload-animation flex flex-col items-center gap-8 mt-2 magic-rings-container">
		<div class="avatar-ripple-wrapper" id="avatar-ripple-wrapper" data-work-start={siteConfig.workHours?.start ?? 9} data-work-end={siteConfig.workHours?.end ?? 18} data-work-days={JSON.stringify(siteConfig.workHours?.workDays ?? [1,2,3,4,5])}>
			<div class="magic-rings-bg" id="magic-rings-bg"></div>
			<a href={url("/about/")} class="group block relative w-44 h-44 overflow-hidden rounded-full border border-(--line-divider) shrink-0 avatar-core">
				<div class="avatar-img avatar-work">
					<ImageWrapper
						src={profileConfig.avatar || ""}
						alt="Profile Image of the Author"
						class="w-full h-full"
						loading="eager"
						fetchpriority="high"
						widths={[400]}
						sizes="400px"
					/>
				</div>
				{profileConfig.avatarOffWork && (
					<div class="avatar-img avatar-off">
						<ImageWrapper
							src={profileConfig.avatarOffWork}
							alt="Profile Image of the Author"
							class="w-full h-full"
							loading="eager"
							widths={[400]}
							sizes="400px"
						/>
					</div>
				)}
			</a>
			<div class="avatar-status-btn" id="avatar-status-btn">
				<span class="status-dot"></span>
				<span class="status-text" id="status-text">下班</span>
			</div>
		</div>
		<div class="text-center w-full">
			<TypewriterText text={profileConfig.bio || ""} speed={80} pauseTime={3000} class="text-xl text-(--content-meta)" />
		</div>
	</section>

	{/* STATS */}
	<div class="home-divider text-center">- - - - -</div>
	<div class="onload-animation mt-4">
		{[stats.slice(0, 4), stats.slice(4)].map((group) => (
			<div class="flex flex-row flex-wrap justify-center gap-x-8 gap-y-4 mb-4">
				{group.map((stat) => (
					<div class="flex flex-col items-center gap-2 min-w-[4.5rem]">
						<div class="flex items-center gap-1.5">
							<Icon name={stat.icon} class="text-base text-neutral-600 dark:text-neutral-300" />
							<span class="text-xs text-neutral-600 dark:text-neutral-300 font-medium">
								{stat.label}
							</span>
						</div>
						{stat.hideValue ? (
							<span class="text-sm font-bold text-neutral-900 dark:text-neutral-100" data-stat-id={stat.id || undefined}>{stat.suffix}</span>
						) : (
							<NumberTicker
								value={stat.value}
								formatted={stat.formatted || false}
								suffix={stat.suffix || ''}
								class="text-sm font-bold text-neutral-900 dark:text-neutral-100"
								client:visible
							/>
						)}
					</div>
				))}
			</div>
		))}
	</div>

	{/* SOCIAL */}
	<div class="home-divider text-center">- - - - -</div>
	<div class="flex items-center justify-center gap-2 flex-wrap">
		{profileConfig.links.map((item) => (
			<a
				rel="me"
				aria-label={item.name}
				href={item.url}
				target={item.url.startsWith("http") ? "_blank" : "_self"}
				class="social-link-btn"
			>
				<Icon name={item.icon} class="text-base" is:inline />
				<span>{item.name}</span>
			</a>
		))}
	</div>

	{/* CATEGORIES */}
	<div class="home-divider text-center">- - - - -</div>
	<section class="section onload-animation">
		<div class="flex flex-wrap justify-center gap-2 px-2 max-w-full overflow-x-auto">
			{categories.map((c) => (
				<a href={c.url} aria-label={`View all posts in ${c.name.trim()}`} class="cat-square-btn text-sm gap-2 shrink-0">
					<span>{c.name.trim()}</span>
					<span class="text-(--content-meta) text-xs">{c.count}</span>
				</a>
			))}
		</div>
	</section>
	<div class="home-divider text-center">- - - - -</div>

</div>

<style>
	.home-portal {
		padding-top: 1rem;
		padding-bottom: 0;
	}

	.home-divider {
		margin-top: 0.75rem;
		margin-bottom: 0.75rem;
		font-size: 0.75rem;
		letter-spacing: 0.25em;
		color: var(--content-meta);
		font-weight: 700;
	}

	/* === Avatar Magic Rings === */
	.avatar-ripple-wrapper {
		position: relative;
		width: 11rem;
		height: 11rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.magic-rings-bg {
		position: absolute;
		top: -3rem;
		bottom: -2.5rem;
		left: -8rem;
		right: -8rem;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}
	.magic-rings-bg canvas {
		width: 100% !important;
		height: 100% !important;
		transform: scaleY(0.45);
	}
	@media (min-width: 768px) {
		.magic-rings-bg {
			left: -20rem;
			right: -20rem;
		}
	}
	[data-time-mode="off"] .magic-rings-bg {
		display: none;
	}
	.avatar-core {
		position: relative;
		z-index: 2;
		transition: border 0.3s ease;
	}
	[data-time-mode="off"] .avatar-core {
		border-width: 3px;
		border-color: #000;
		box-sizing: border-box;
	}
	:root.dark [data-time-mode="off"] .avatar-core {
		border-color: #fff;
	}
	.avatar-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}
	.avatar-img.avatar-off {
		display: none;
	}
	[data-time-mode="off"] .avatar-img.avatar-work {
		display: none;
	}
	[data-time-mode="off"] .avatar-img.avatar-off {
		display: block;
	}

	/* === Status Button === */
	.avatar-status-btn {
		position: absolute;
		bottom: -0.5rem;
		left: 50%;
		transform: translateX(-50%);
		z-index: 10;
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.25rem 0.75rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		font-weight: 500;
		white-space: nowrap;
		border: 2px solid #000;
		color: #000;
		background: #fff;
	}
	:root.dark .avatar-status-btn {
		border-color: #fff;
		color: #fff;
		background: #000;
	}
	/* 上班时间粉色 */
	[data-time-mode="work"] .avatar-status-btn {
		border-color: oklch(0.65 0.2 350);
		color: oklch(0.65 0.2 350);
		background: #fff;
	}
	:root.dark [data-time-mode="work"] .avatar-status-btn {
		border-color: oklch(0.65 0.2 350);
		color: oklch(0.65 0.2 350);
		background: #000;
	}

	.status-dot {
		width: 0.375rem;
		height: 0.375rem;
		border-radius: 9999px;
		background: #000;
		flex-shrink: 0;
	}
	:root.dark .status-dot {
		background: #fff;
	}
	[data-time-mode="work"] .status-dot {
		background: oklch(0.65 0.2 350);
		animation: status-pulse 1.5s ease-in-out infinite;
	}

	@keyframes status-pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.3; }
	}

	.social-link-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.375rem 0.875rem;
		border: 1px solid #000;
		color: #000;
		background: #fff;
		border-radius: 9999px;
		font-size: 0.8125rem;
		text-decoration: none;
		transition: color 150ms, background-color 150ms;
	}
	.social-link-btn:hover {
		background-color: #000;
		color: #fff;
	}
	:root.dark .social-link-btn {
		border-color: #fff;
		color: #fff;
		background: #000;
	}
	:root.dark .social-link-btn:hover {
		background-color: #fff;
		color: #000;
	}

	.cat-square-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.375rem 1rem;
		border: 1px solid black;
		color: black;
		background: #fff;
		border-radius: 9999px;
		transition: color 150ms, background-color 150ms;
	}
	.cat-square-btn:hover {
		background-color: black;
		color: white;
	}
	:root.dark .cat-square-btn {
		border-color: white;
		color: white;
		background: black;
	}
	:root.dark .cat-square-btn:hover {
		background-color: white;
		color: black;
	}
</style>

<script>
import { initMagicRings } from '@components/features/MagicRings.ts';

(function() {
	var ringsInstance = null;

	function getIsWork(wrapper) {
		var start = parseInt(wrapper.dataset.workStart || '9') || 9;
		var end = parseInt(wrapper.dataset.workEnd || '18') || 18;
		var workDays = [1,2,3,4,5];
		try { workDays = JSON.parse(wrapper.dataset.workDays || '[1,2,3,4,5]'); } catch(e) {}
		var now = new Date();
		var day = now.getDay();
		var hour = now.getHours();
		var isWorkDay = workDays.indexOf(day) !== -1;
		return isWorkDay && hour >= start && hour < end;
	}

	function setTimeMode() {
		var wrapper = document.getElementById('avatar-ripple-wrapper');
		var statusText = document.getElementById('status-text');
		if (!wrapper) return;
		var isWork = getIsWork(wrapper);
		wrapper.setAttribute('data-time-mode', isWork ? 'work' : 'off');
		if (statusText) statusText.textContent = isWork ? '上班中' : '下班';
	}

	function initRings() {
		var container = document.getElementById('magic-rings-bg');
		var wrapper = document.getElementById('avatar-ripple-wrapper');
		if (!container || !wrapper) return;
		if (ringsInstance) {
			ringsInstance.destroy();
			ringsInstance = null;
		}
		var isWork = getIsWork(wrapper);
		if (isWork) {
			ringsInstance = initMagicRings(container, {
				color: '#E24EA0',
				colorTwo: '#F97316',
				ringCount: 6,
				speed: 1,
				attenuation: 10,
				lineThickness: 2,
				baseRadius: 0.35,
				radiusStep: 0.1,
				scaleRate: 0.1,
				opacity: 1,
				noiseAmount: 0,
				rotation: 0,
				ringGap: 1.5,
				fadeIn: 0.7,
				fadeOut: 0.5,
				followMouse: true,
				mouseInfluence: 0.2,
				hoverScale: 1.2,
				parallax: 0.05,
				clickBurst: true,
			});
		}
	}

	setTimeMode();
	initRings();
	setInterval(setTimeMode, 60000);

	document.addEventListener('astro:page-load', function() {
		setTimeMode();
		initRings();
	});
})();
</script>

<script is:inline>
(function() {
	function updateCounter() {
		var uvEl = document.querySelector('[data-stat-id="counter-uv"]');
		var pvEl = document.querySelector('[data-stat-id="counter-pv"]');
		if (!uvEl || !pvEl) return;

		fetch('/api/count', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ path: location.pathname }),
		})
		.then(function(r) { return r.json(); })
		.then(function(data) {
			if (data.uv != null) uvEl.textContent = Number(data.uv).toLocaleString();
			if (data.pv != null) pvEl.textContent = Number(data.pv).toLocaleString();
		})
		.catch(function() {});
	}

	updateCounter();
	document.addEventListener('swup:contentReplaced', function() {
		setTimeout(updateCounter, 200);
	});
})();
</script>
