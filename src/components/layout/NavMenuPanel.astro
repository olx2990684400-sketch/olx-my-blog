---
import Icon from "@components/common/Icon.astro";
import { LinkPresets } from "@/constants/link-presets";
import { LinkPreset, type NavBarLink } from "@/types/config";
import { siteConfig } from "@/config";
import { profileConfig } from "@/config/profileConfig";
import { url } from "@/utils/url-utils";

interface Props {
	links: NavBarLink[];
}

const imageFiles = import.meta.glob<{ default: ImageMetadata }>(
	"../../assets/images/**/*.{png,jpg,jpeg,webp,avif,gif}",
	{ import: "default" },
);

async function resolveAvatar(src?: string) {
	if (!src) return "";
	if (src.startsWith("/") || src.startsWith("http://") || src.startsWith("https://") || src.startsWith("data:")) {
		return src;
	}
	const normalizedPath = `../../${src}`.replace(/\\/g, "/");
	const loadImage = imageFiles[normalizedPath];
	if (!loadImage) return `/${src}`;
	const image = await loadImage();
	return image.src;
}

const avatarUrl = await resolveAvatar(profileConfig.avatar);

const processedLinks = Astro.props.links.map((link: NavBarLink) => ({
	...link,
	children: link.children?.map((child: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof child === "number") {
			return LinkPresets[child];
		}
		return child;
	}),
}));
---

<div id="nav-drawer-overlay" class="nav-drawer-overlay" aria-hidden="true"></div>

<div id="nav-menu-panel" class="nav-drawer">
	<div class="nav-drawer-profile">
		<div class="nav-drawer-avatar-wrap">
			<img
				src={avatarUrl}
				alt={profileConfig.name}
				class="nav-drawer-avatar"
			/>
		</div>
		<div class="nav-drawer-profile-info">
			<div class="nav-drawer-profile-name">{profileConfig.displayName || profileConfig.name}</div>
			{profileConfig.occupation && (
				<div class="nav-drawer-profile-occupation">{profileConfig.occupation}</div>
			)}
		</div>
		<div class="nav-drawer-social-links">
			{profileConfig.links.map((link) => (
				<a
					href={link.url}
					target="_blank"
					rel="noopener noreferrer"
					class="nav-drawer-social-link"
					title={link.name}
				>
					<Icon name={link.icon} is:inline class="text-[1.25rem]" />
				</a>
			))}
		</div>
	</div>

	<nav class="nav-drawer-body">
		{processedLinks.map((link, index) => (
			<div
				class="nav-drawer-item"
				style={`--item-index: ${index}`}
			>
				{link.children && link.children.length > 0 ? (
					<div class="mobile-dropdown" data-collapsible="true" data-collapsed="false">
						<button type="button" class="nav-drawer-link group nav-drawer-toggle">
							<div class="flex items-center gap-3">
								{link.icon && <Icon name={link.icon} is:inline class="text-[1.25rem] nav-drawer-icon" />}
								<span class="nav-drawer-link-text">{link.name}</span>
							</div>
							<Icon name="material-symbols:keyboard-arrow-down-rounded" is:inline class="text-[1.25rem] nav-drawer-arrow" />
						</button>
						<div class="mobile-submenu">
							{link.children.map((child) => {
								if (child.action) {
									return <button type="button" class="nav-drawer-sublink group" data-action={child.action}><div class="flex items-center gap-3">{child.icon && <Icon name={child.icon} is:inline class="text-[1.1rem]" />}<span>{child.name}</span></div></button>;
								}
								const noSwup = ['/friends/', '/collections/', '/moments/', '/bangumi/', '/write/', '/config/'].includes(child.url);
								return <a href={child.external ? child.url : url(child.url)} class="nav-drawer-sublink group" target={child.external ? "_blank" : null} {...(noSwup ? { 'data-no-swup': true } : {})}><div class="flex items-center gap-3">{child.icon && <Icon name={child.icon} is:inline class="text-[1.1rem]" />}<span>{child.name}</span></div>{child.external && <Icon name="fa7-solid:arrow-up-right-from-square" is:inline class="text-[0.7rem] text-black/25 dark:text-white/25" />}</a>;
							})}
						</div>
					</div>
				) : (
					<a href={link.external ? link.url : url(link.url)}
						class="nav-drawer-link group"
						target={link.external ? "_blank" : null}
					>
						<div class="flex items-center gap-3">
							{link.icon && <Icon name={link.icon} is:inline class="text-[1.25rem] nav-drawer-icon" />}
							<span class="nav-drawer-link-text">{link.name}</span>
						</div>
						{link.external && <Icon name="fa7-solid:arrow-up-right-from-square" is:inline
							class="text-[0.7rem] text-black/25 dark:text-white/25"
						/>}
					</a>
				)}
			</div>
		))}
	</nav>

	<div class="nav-drawer-footer">
		<a href={url('/config/')} class="nav-drawer-link group" data-no-swup>
			<div class="flex items-center gap-3">
				<Icon name="material-symbols:settings-rounded" is:inline class="text-[1.25rem] nav-drawer-icon" />
				<span class="nav-drawer-link-text">站点设置</span>
			</div>
		</a>
		<a href={url('/')} class="nav-drawer-link group">
			<div class="flex items-center gap-3">
				<Icon name="material-symbols:home-pin-outline" is:inline class="text-[1.25rem] nav-drawer-icon" />
				<span class="nav-drawer-link-text">返回首页</span>
			</div>
		</a>
	</div>
</div>

<!-- 样式已迁移至 src/styles/layout/nav-menu-panel.css -->

<script>
let drawerAbortController: AbortController | null = null;

function initNavDrawer() {
	if (drawerAbortController) drawerAbortController.abort();
	drawerAbortController = new AbortController();
	const signal = drawerAbortController.signal;

	const panelEl = document.getElementById('nav-menu-panel');
	const overlayEl = document.getElementById('nav-drawer-overlay');
	const menuBtn = document.getElementById('nav-menu-switch');
	const closeBtn = document.getElementById('nav-drawer-close');

	if (!panelEl || !overlayEl) return;

	const panel = panelEl;
	const overlay = overlayEl;

	function openDrawer() {
		panel.classList.add('is-open');
		overlay.classList.add('is-open');
		overlay.setAttribute('aria-hidden', 'false');
		document.body.style.overflow = 'hidden';
	}

	function closeDrawer() {
		panel.classList.remove('is-open');
		overlay.classList.remove('is-open');
		overlay.setAttribute('aria-hidden', 'true');
		document.body.style.overflow = '';
	}

	function toggleCollapsible(toggleEl: HTMLElement) {
		const dropdown = toggleEl.closest('[data-collapsible]');
		if (!dropdown) return;
		const isCollapsed = dropdown.getAttribute('data-collapsed') === 'true';
		dropdown.setAttribute('data-collapsed', isCollapsed ? 'false' : 'true');
	}

	closeDrawer();

	if (menuBtn) {
		menuBtn.onclick = (e) => {
			e.stopPropagation();
			const isOpen = panel.classList.contains('is-open');
			if (isOpen) {
				closeDrawer();
			} else {
				openDrawer();
			}
		};
	}

	if (closeBtn) {
		closeBtn.onclick = () => closeDrawer();
	}

	overlay.addEventListener('click', () => closeDrawer(), { signal });

	// 处理折叠/展开
	panel.addEventListener('click', (e) => {
		const toggleEl = (e.target as HTMLElement).closest('.nav-drawer-toggle');
		if (toggleEl) {
			e.stopPropagation();
			toggleCollapsible(toggleEl as HTMLElement);
			return;
		}

		// 处理 action 按钮
		const actionBtn = (e.target as HTMLElement).closest('[data-action]');
		if (actionBtn) {
			const action = actionBtn.getAttribute('data-action');
			if (action) {
				window.dispatchEvent(new CustomEvent(action));
				closeDrawer();
			}
		}
	}, { signal });

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && panel.classList.contains('is-open')) {
			closeDrawer();
		}
	}, { signal });
}

initNavDrawer();

document.addEventListener('astro:page-load', () => {
	initNavDrawer();
});
</script>
